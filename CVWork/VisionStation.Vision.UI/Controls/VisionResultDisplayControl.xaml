<UserControl x:Class="VisionStation.Vision.UI.Controls.VisionResultDisplayControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls"
             xmlns:converters="clr-namespace:VisionStation.Vision.UI.Converters">
    <UserControl.Resources>
        <converters:ImageFrameToBitmapSourceConverter x:Key="ImageFrameToBitmapSourceConverter" />
    </UserControl.Resources>

    <controls:ZoomableImageSurface ImageFrame="{Binding ImageFrame, ElementName=Root}"
                                   OverlayItemsSource="{Binding OverlayItemsSource, ElementName=Root}"
                                   CanOpenFullscreen="{Binding CanOpenFullscreen, ElementName=Root}"
                                   ShowToolbar="{Binding ShowToolbar, ElementName=Root}"
                                   ShowPixelInfo="{Binding ShowPixelInfo, ElementName=Root}"
                                   ShowZoomInfo="{Binding ShowZoomInfo, ElementName=Root}"
                                   Background="{StaticResource ImageSurfaceBackgroundBrush}">
        <Grid Background="{StaticResource ImageSurfaceBackgroundBrush}">
            <Image Source="{Binding ImageFrame, ElementName=Root, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True" />

            <controls:ResultOverlayCanvas ImageFrame="{Binding ImageFrame, ElementName=Root}"
                                          ItemsSource="{Binding OverlayItemsSource, ElementName=Root}"
                                          IsHitTestVisible="False" />

            <Border HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="12"
                    Padding="10,6"
                    MinWidth="86"
                    Background="#DD0B1117"
                    BorderBrush="{Binding ResultBrush, ElementName=Root}"
                    BorderThickness="1"
                    CornerRadius="5"
                    IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasResult, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ShowIdleState, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource IconTextStyle}"
                               Text="&#xE8FB;"
                               Width="20"
                               FontSize="14"
                               Foreground="{Binding ResultBrush, ElementName=Root}" />
                    <TextBlock Text="{Binding ResultText, ElementName=Root}"
                               Margin="7,0,0,0"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{Binding ResultBrush, ElementName=Root}" />
                </StackPanel>
            </Border>
        </Grid>
    </controls:ZoomableImageSurface>
</UserControl>
