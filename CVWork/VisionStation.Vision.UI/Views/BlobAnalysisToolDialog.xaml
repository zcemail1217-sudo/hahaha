<Window x:Class="VisionStation.Vision.UI.Views.BlobAnalysisToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:VisionStation.Vision.UI.Behaviors"
        xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls"
        xmlns:converters="clr-namespace:VisionStation.Vision.UI.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="740"
        MinWidth="1040"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImageFrameToBitmapSourceConverter x:Key="ImageFrameToBitmapSourceConverter" />

        <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="BlobTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="58" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,0,1">
            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RunToolCommand}" Click="CommitFocusedInput_OnClick" Style="{StaticResource HeaderIconButtonStyle}" ToolTip="运行斑点分析">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE768;" FontSize="15" />
                    </Button>
                    <Button Command="{Binding EditRoiCommand}" Style="{StaticResource HeaderIconButtonStyle}" ToolTip="编辑搜索区域">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE9D9;" FontSize="15" />
                    </Button>
                    <Button Command="{Binding CloseCommand}" Style="{StaticResource HeaderIconButtonStyle}" ToolTip="返回流程">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE72B;" FontSize="15" />
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding WindowTitle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="启用"
                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                              Margin="0,0,14,0"
                              VerticalAlignment="Center"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="Minimize"
                            ToolTip="最小化">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE921;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="ToggleMaximize"
                            ToolTip="最大化/还原">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE922;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                            Command="{Binding CloseCommand}"
                            ToolTip="关闭">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8BB;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="520" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="Black"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <controls:ZoomableImageSurface ImageFrame="{Binding CurrentFrame}"
                                               OverlayItemsSource="{Binding PreviewOverlays}"
                                               Background="Black">
                    <Grid Background="Black">
                        <Image Source="{Binding CurrentFrame, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True" />
                        <controls:ResultOverlayCanvas ImageFrame="{Binding CurrentFrame}"
                                                      ItemsSource="{Binding PreviewOverlays}"
                                                      IsHitTestVisible="False" />
                        <controls:RoiEditorCanvas ImageFrame="{Binding CurrentFrame}"
                                                  ItemsSource="{Binding EditableRois}"
                                                  SelectedRoi="{Binding SelectedEditableRoi, Mode=TwoWay}"
                                                  PlacementCommand="{Binding PlaceRoiCommand}"
                                                  IsPlacementArmed="{Binding IsRoiPlacementArmed}"
                                                  Focusable="True" />
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,12,0,0"
                                Padding="12,7"
                                Background="#DD0B1117"
                                BorderBrush="{StaticResource AccentLineBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsRoiPlacementArmed, Converter={StaticResource BooleanToVisibilityConverter}}"
                                IsHitTestVisible="False">
                            <TextBlock Text="{Binding RoiPlacementHint}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Grid Visibility="{Binding ShowCrosshair, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False">
                            <Border Width="1" Background="{StaticResource AccentLineBrush}" HorizontalAlignment="Center" Opacity="0.45" />
                            <Border Height="1" Background="{StaticResource AccentLineBrush}" VerticalAlignment="Center" Opacity="0.45" />
                        </Grid>
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420"
                                Padding="18,14"
                                Background="#E60B1117"
                                BorderBrush="{StaticResource WarnBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsMissingInputImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                IsHitTestVisible="False">
                            <StackPanel>
                                <TextBlock Text="未连接输入图像"
                                           Foreground="{StaticResource WarnBrush}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding MissingInputImageText}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </controls:ZoomableImageSurface>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding Title}"
                                            Style="{StaticResource BlobTabButtonStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Grid Grid.Row="1" Margin="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsHomeTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="基础" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ROI" Style="{StaticResource FormLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              ItemsSource="{Binding RoiShapeOptions}"
                                              SelectedItem="{Binding SelectedRoiShape, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              Height="30" />
                                    <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                            Command="{Binding EditRoiCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Content="编辑搜索区域" />
                                </Grid>

                                <TextBlock Text="快速参数" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="场景" Style="{StaticResource FormLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding Presets}"
                                              SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              Height="30" />
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Command="{Binding ApplyPresetCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Content="应用" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding SelectedPresetDescription}"
                                               Style="{StaticResource HintTextStyle}" />
                                </Grid>

                                <TextBlock Text="灰度分割" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="模式" Style="{StaticResource FormLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding ThresholdModes}"
                                              SelectedItem="{Binding ThresholdMode, Mode=TwoWay}"
                                              Height="30" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="极性" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <ComboBox Grid.Row="0" Grid.Column="3"
                                              ItemsSource="{Binding Polarities}"
                                              SelectedItem="{Binding Polarity, Mode=TwoWay}"
                                              Height="30" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="灰度下限" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GrayMin, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="灰度上限" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding GrayMax, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="单阈值" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="选择" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <ComboBox Grid.Row="2" Grid.Column="3"
                                              ItemsSource="{Binding ResultSelections}"
                                              SelectedItem="{Binding Selection, Mode=TwoWay}"
                                              Height="30" />
                                </Grid>
                                <TextBlock Text="{Binding ThresholdModeHint}" Style="{StaticResource HintTextStyle}" />
                                <TextBlock Text="{Binding PolarityHint}" Style="{StaticResource HintTextStyle}" />
                                <TextBlock Text="{Binding SelectionHint}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,14" />

                                <TextBlock Text="高级分割" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="块大小" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Column="1" Text="{Binding AdaptiveBlockSize, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Column="2" Text="修正 C" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Column="3" Text="{Binding AdaptiveC, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>
                                <TextBlock Text="{Binding AdvancedThresholdHint}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,14" />

                                <TextBlock Text="筛选" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="最小面积" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MinArea, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="最大面积" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MaxArea, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最小圆度" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinCircularity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="最大圆度" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MaxCircularity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="最小比例" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MinAspectRatio, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="最大比例" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding MaxAspectRatio, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="数量下限" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MinCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="数量上限" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding MaxCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>
                                <TextBlock Text="{Binding FilterHint}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,14" />

                                <TextBlock Text="宽高筛选" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="最小宽度" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MinWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="最大宽度" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MaxWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最小高度" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinHeight, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="最大高度" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MaxHeight, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>
                                <TextBlock Text="{Binding SizeFilterHint}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,14" />

                                <TextBlock Text="形态学" Style="{StaticResource SectionCaptionStyle}" />
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="开运算" Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Grid.Column="1" Text="{Binding MorphOpen, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Grid.Column="2" Text="闭运算" Style="{StaticResource FormLabelStyle}" Margin="14,0,8,0" />
                                    <TextBox Grid.Column="3" Text="{Binding MorphClose, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>
                                <TextBlock Text="{Binding MorphologyHint}" Style="{StaticResource HintTextStyle}" Margin="0,0,0,14" />

                            </StackPanel>
                        </ScrollViewer>

                        <Grid Visibility="{Binding IsResultTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="运行摘要" Style="{StaticResource SectionCaptionStyle}" />
                                <ItemsControl ItemsSource="{Binding ResultItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,8"
                                                    Padding="10,6"
                                                    Background="{StaticResource SurfaceAltBrush}"
                                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                                    BorderThickness="1"
                                                    CornerRadius="3">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Text="{Binding Value}"
                                                               Margin="0,2,0,0"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="斑点明细" Style="{StaticResource SectionCaptionStyle}" />
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding BlobDetails}"
                                          SelectedItem="{Binding SelectedBlobDetail, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="46" />
                                        <DataGridTextColumn Header="中心" Binding="{Binding Center}" Width="150" />
                                        <DataGridTextColumn Header="面积" Binding="{Binding Area}" Width="86" />
                                        <DataGridTextColumn Header="圆度" Binding="{Binding Circularity}" Width="78" />
                                        <DataGridTextColumn Header="长宽比" Binding="{Binding AspectRatio}" Width="84" />
                                        <DataGridTextColumn Header="周长" Binding="{Binding Perimeter}" Width="78" />
                                        <DataGridTextColumn Header="尺寸" Binding="{Binding Size}" Width="96" />
                                        <DataGridTextColumn Header="外接矩形" Binding="{Binding Rect}" Width="170" />
                                        <DataGridTextColumn Header="外接圆" Binding="{Binding Circle}" Width="170" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsOutputTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="输出项" Style="{StaticResource SectionCaptionStyle}" />
                                <ItemsControl ItemsSource="{Binding OutputOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" Margin="0,0,10,10">
                                                <Border Padding="10,6"
                                                        Background="{Binding SoftFill}"
                                                        BorderBrush="{Binding Stroke}"
                                                        BorderThickness="1"
                                                        CornerRadius="3">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="8"
                                                                 Height="8"
                                                                 Fill="{Binding Stroke}"
                                                                 Margin="0,0,6,0"
                                                                 VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Name}" />
                                                    </StackPanel>
                                                </Border>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsDisplayTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="显示" Style="{StaticResource SectionCaptionStyle}" />
                                <CheckBox Content="显示搜索区域" IsChecked="{Binding ShowRoi, Mode=TwoWay}" Margin="0,0,0,10" />
                                <CheckBox Content="显示编号标签" IsChecked="{Binding ShowResultLabel, Mode=TwoWay}" Margin="0,0,0,10" />
                                <CheckBox Content="显示十字参考线" IsChecked="{Binding ShowCrosshair, Mode=TwoWay}" Margin="0,0,0,10" />
                                <TextBlock Text="{Binding InputFrameInfo}"
                                           Margin="0,16,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ItemsControl ItemsSource="{Binding ResultItems}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10,5"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="：" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding Value}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding RunToolCommand}" Click="CommitFocusedInput_OnClick" Style="{StaticResource ActionButtonStyle}" MinWidth="96" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE768;" Width="18" />
                            <TextBlock Text="运行" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelCommand}" Style="{StaticResource ActionButtonStyle}" MinWidth="88" Content="取消" Margin="0,0,8,0" />
                    <Button Command="{Binding CloseCommand}" Click="CommitFocusedInput_OnClick" Style="{StaticResource ActionButtonStyle}" MinWidth="88" Content="确定" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
