<UserControl x:Class="VisionStation.Vision.UI.Views.CalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls"
             xmlns:converters="clr-namespace:VisionStation.Vision.UI.Converters"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImageFrameToBitmapSourceConverter x:Key="ImageFrameToBitmapSourceConverter" />

        <Style x:Key="CalibrationTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4"
                                    HorizontalAlignment="Left">
                                <TabPanel IsItemsHost="True" Background="Transparent" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="0,12,0,0" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalibrationTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="16,7">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2033D6A6" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE7B7;" Width="28" />
                <StackPanel Margin="8,0,0,0">
                    <TextBlock Text="视觉标定" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentRecipeText}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Command="{Binding BackToVisionCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,8,0">
                    <TextBlock Text="打开视觉流程" />
                </Button>
                <Button Command="{Binding ReloadCommand}"
                        Style="{StaticResource ActionButtonStyle}">
                    <TextBlock Text="重新载入" />
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource PanelBorderStyle}"
                MinHeight="64"
                Padding="12,8"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center" MinHeight="42">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="1"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               LineHeight="18"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="平面映射"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   LineHeight="17"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="XY 九点 -> 找点工具 -> 像素到轴坐标"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   LineHeight="16"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2" VerticalAlignment="Center" MinHeight="42">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="2"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               LineHeight="18"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="相机内参"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   LineHeight="17"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="目录棋盘图 -> 角点 -> 相机矩阵/畸变"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   LineHeight="16"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="4" VerticalAlignment="Center" MinHeight="42">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="3"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               LineHeight="18"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="运行调用"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   LineHeight="17"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="坐标转换工具读取当前配方标定"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   LineHeight="16"
                                   LineStackingStrategy="BlockLineHeight"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedCalibrationTabIndex}"
                    IsEnabled="{Binding CanRunAutomation}"
                    Style="{StaticResource CalibrationTabControlStyle}"
                    ItemContainerStyle="{StaticResource CalibrationTabItemStyle}">
            <TabItem Header="平面标定">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8B9;" Width="24" />
                                        <TextBlock Text="自动九点平面标定" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding PlaneStatusText}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>

                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10,7"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding PlaneProgressText}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                </Border>

                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10,7"
                                        Margin="0,0,0,12">
                                    <TextBlock Text="{Binding PlaneQualityText}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                </Border>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="视觉找点工具" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding PointToolOptions}"
                                              SelectedItem="{Binding SelectedPointTool}"
                                              MinHeight="32" />
                                </StackPanel>

                                <UniformGrid Columns="2" Margin="0,0,0,4">
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="X轴" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding AxisXKeyText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Y轴" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding AxisYKeyText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="X步距" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding GridStepXText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Y步距" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding GridStepYText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="单位" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding PlaneUnitText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="模型" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <ComboBox ItemsSource="{Binding PlaneModels}"
                                                  SelectedItem="{Binding SelectedPlaneModel}"
                                                  MinHeight="32" />
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="RANSAC" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding RansacThresholdText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="32"
                                             ToolTip="RANSAC误差阈值" />
                                </StackPanel>

                                <Expander Header="高级运动设置"
                                          IsExpanded="{Binding IsAdvancedPlaneSettingsExpanded}"
                                          Margin="0,0,0,12">
                                    <StackPanel Margin="0,10,0,0">
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Text="速度" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                                <TextBox Text="{Binding MotionSpeedText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="加速度" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                                <TextBox Text="{Binding MotionAccelerationText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Text="稳定延时ms" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                                <TextBox Text="{Binding SettleDelayMsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <CheckBox IsChecked="{Binding UseEncoderPosition}"
                                                  Content="使用编码器反馈"
                                                  Margin="0,0,0,8" />
                                        <CheckBox IsChecked="{Binding ReturnToStartAfterAuto}"
                                                  Content="完成后回起点" />
                                    </StackPanel>
                                </Expander>

                                <StackPanel>
                                    <Button Command="{Binding RunAutoPlaneCalibrationCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,0,0,8">
                                        <TextBlock Text="跑九点并保存" />
                                    </Button>
                                    <UniformGrid Columns="3">
                                        <Button Command="{Binding CalculatePlaneCommand}" Style="{StaticResource ActionButtonStyle}">
                                            <TextBlock Text="重新计算" />
                                        </Button>
                                        <Button Command="{Binding SavePlaneCommand}" Style="{StaticResource ActionButtonStyle}">
                                            <TextBlock Text="保存当前矩阵" />
                                        </Button>
                                        <Button Command="{Binding ClearAutoPlaneSamplesCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0">
                                            <TextBlock Text="清空" />
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="180" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="Black"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1">
                            <controls:ZoomableImageSurface ImageFrame="{Binding SelectedAutoPlaneFrame}"
                                                           OverlayItemsSource="{Binding AutoPlaneOverlays}"
                                                           CanOpenFullscreen="False"
                                                           Background="Black">
                                <Grid Background="Black">
                                    <Image Source="{Binding SelectedAutoPlaneFrame, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True" />
                                    <controls:ResultOverlayCanvas ImageFrame="{Binding SelectedAutoPlaneFrame}"
                                                                  ItemsSource="{Binding AutoPlaneOverlays}"
                                                                  IsHitTestVisible="False" />
                                    <Border HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#CC0B1117"
                                            BorderBrush="{StaticResource AccentLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="14,9"
                                            Visibility="{Binding IsAutoPlanePreviewMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="自动采集后，选中点位可预览视觉找点位置"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>
                                </Grid>
                            </controls:ZoomableImageSurface>
                        </Border>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding AutoPlaneSamples}"
                                  SelectedItem="{Binding SelectedAutoPlaneSample}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="42" />
                                <DataGridTextColumn Header="目标X" Binding="{Binding TargetX}" Width="76" />
                                <DataGridTextColumn Header="目标Y" Binding="{Binding TargetY}" Width="76" />
                                <DataGridTextColumn Header="实际X" Binding="{Binding ActualX}" Width="76" />
                                <DataGridTextColumn Header="实际Y" Binding="{Binding ActualY}" Width="76" />
                                <DataGridTextColumn Header="像素X" Binding="{Binding ImageX}" Width="76" />
                                <DataGridTextColumn Header="像素Y" Binding="{Binding ImageY}" Width="76" />
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60" />
                                <DataGridTextColumn Header="信息/失败原因" Binding="{Binding Message}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="4"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock Text="平面结果"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding PlaneQualitySummary.Label}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold" />
                                </Grid>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding PlaneQualitySummary.Details}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding PlaneQualitySummary.MaxErrorPointText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBlock Grid.Row="3"
                                           Text="{Binding PlaneResultText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBox Grid.Row="4"
                                         Text="{Binding PlaneMatrixText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="相机内参">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE722;" Width="24" />
                                        <TextBlock Text="相机内参标定" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding CameraStatusText}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>

                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10,7"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding CameraProgressText}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                </Border>

                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10,7"
                                        Margin="0,0,0,12">
                                    <TextBlock Text="{Binding CameraQualityText}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                </Border>

                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="列内角点" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding ChessboardColumnsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="行内角点" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding ChessboardRowsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="格距" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding SquareSizeText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="单位" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding CameraUnitText, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                                    </StackPanel>
                                </UniformGrid>

                                <Button Command="{Binding RunCameraDirectoryCalibrationCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,0,0,8">
                                    <TextBlock Text="选择目录并计算" />
                                </Button>
                                <Button Command="{Binding SaveCameraCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,0,0,8">
                                    <TextBlock Text="保存内参到配方" />
                                </Button>
                                <Button Command="{Binding ClearCameraImagesCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0">
                                    <TextBlock Text="清空" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="210" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="Black"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1">
                            <controls:ZoomableImageSurface ImageFrame="{Binding SelectedChessboardFrame}"
                                                           OverlayItemsSource="{Binding ChessboardOverlays}"
                                                           CanOpenFullscreen="False"
                                                           Background="Black">
                                <Grid Background="Black">
                                    <Image Source="{Binding SelectedChessboardFrame, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True" />
                                    <controls:ResultOverlayCanvas ImageFrame="{Binding SelectedChessboardFrame}"
                                                                  ItemsSource="{Binding ChessboardOverlays}"
                                                                  IsHitTestVisible="False" />
                                    <Border HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#CC0B1117"
                                            BorderBrush="{StaticResource AccentLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="14,9"
                                            Visibility="{Binding IsChessboardPreviewMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="选择目录后，选中列表图片可预览角点"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>
                                </Grid>
                            </controls:ZoomableImageSurface>
                        </Border>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding ChessboardObservations}"
                                  SelectedItem="{Binding SelectedObservation}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="图片" Binding="{Binding FileName}" Width="2*" />
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="64" />
                                <DataGridTextColumn Header="尺寸" Binding="{Binding ImageSize}" Width="96" />
                                <DataGridTextColumn Header="角点" Binding="{Binding PointCount}" Width="64" />
                                <DataGridTextColumn Header="信息/失败原因" Binding="{Binding Message}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="4"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock Text="相机结果"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding CameraQualitySummary.Label}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold" />
                                </Grid>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding CameraQualitySummary.Details}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding CameraResultText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBox Grid.Row="3"
                                         Text="{Binding CameraMatrixText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,8,0,4" />
                                <TextBox Grid.Row="4"
                                         Text="{Binding DistortionText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
