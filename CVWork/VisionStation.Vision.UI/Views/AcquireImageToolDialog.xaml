<Window x:Class="VisionStation.Vision.UI.Views.AcquireImageToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:VisionStation.Vision.UI.Behaviors"
        xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls"
        xmlns:converters="clr-namespace:VisionStation.Vision.UI.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="1040"
        Height="680"
        MinWidth="920"
        MinHeight="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImageFrameToBitmapSourceConverter x:Key="ImageFrameToBitmapSourceConverter" />

        <Style x:Key="DialogIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="SourceTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="8,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeIconStyle" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="72" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="16"
                                Padding="7,0">
                            <Grid>
                                <TextBlock x:Name="OnText"
                                           Text="开"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="OffText"
                                           Text="关"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Visibility="Collapsed" />
                                <Border x:Name="Knob"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="11"
                                        Background="{StaticResource TextPrimaryBrush}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="OnText" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="OffText" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="62" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,0,1">
            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RunToolCommand}" Style="{StaticResource DialogIconButtonStyle}" ToolTip="{Binding PrimaryActionText}">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE722;" FontSize="16" />
                    </Button>
                    <Button Command="{Binding SaveImageCommand}" Style="{StaticResource DialogIconButtonStyle}" ToolTip="图像另存">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE74E;" FontSize="16" />
                    </Button>
                    <Button Command="{Binding CloseCommand}" Style="{StaticResource DialogIconButtonStyle}" ToolTip="返回流程">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE72B;" FontSize="16" />
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding WindowTitle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="Minimize"
                            ToolTip="最小化">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE921;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="ToggleMaximize"
                            ToolTip="最大化/还原">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE922;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                            Command="{Binding CloseCommand}"
                            ToolTip="关闭">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8BB;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="410" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="Black"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <controls:ZoomableImageSurface ImageFrame="{Binding CurrentFrame}" Background="Black">
                    <Grid Background="Black">
                        <Image Source="{Binding CurrentFrame, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True" />

                        <TextBlock Text="图像预览"
                                   Margin="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top" />

                        <Grid Visibility="{Binding ShowCrosshair, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False">
                            <Border Width="1"
                                    Background="{StaticResource AccentLineBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch" />
                            <Border Height="1"
                                    Background="{StaticResource AccentLineBrush}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </controls:ZoomableImageSurface>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding SourceTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectSourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SourceTabButtonStyle}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Style="{StaticResource ModeIconStyle}">
                                                <TextBlock Style="{StaticResource IconTextStyle}"
                                                           Text="{Binding Icon}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#AA0B1117"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="{Binding PrimaryActionText}" Style="{StaticResource PanelTitleStyle}" />
                            <TextBlock Text="{Binding SourceDescription}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="16,14">
                            <StackPanel Visibility="{Binding IsCameraSource, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="设备列表" Style="{StaticResource FormLabelStyle}" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="84" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding DeviceList}"
                                              SelectedItem="{Binding SelectedCameraDevice, Mode=TwoWay}"
                                              Height="34"
                                              Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Command="{Binding RefreshDevicesCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="刷新"
                                            MinWidth="76"
                                            Margin="0" />
                                </Grid>
                                <TextBlock Text="{Binding SelectedCameraDevice.Details}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />

                                <TextBlock Text="相机序列号" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding CameraSerial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True"
                                         Height="32"
                                         Margin="0,0,0,16" />

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="曝光时间:"
                                               Style="{StaticResource FormLabelStyle}"
                                               VerticalAlignment="Center"
                                               Margin="0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ExposureTimeUs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.#}}"
                                             Height="32"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="us"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    <Slider Grid.Column="0"
                                            Grid.ColumnSpan="4"
                                            Margin="0,38,0,0"
                                            Minimum="0"
                                            Maximum="1000000"
                                            Value="{Binding ExposureTimeUs, Mode=TwoWay}" />
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="心跳超时:"
                                               Style="{StaticResource FormLabelStyle}"
                                               VerticalAlignment="Center"
                                               Margin="0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding HeartbeatTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="ms"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Text="触发源选择" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox ItemsSource="{Binding TriggerSources}"
                                          SelectedItem="{Binding TriggerSource, Mode=TwoWay}"
                                          Height="34"
                                          Margin="0,0,0,14" />

                                <CheckBox Content="软件触发前清理旧帧缓存"
                                          IsChecked="{Binding ClearBufferBeforeTrigger, Mode=TwoWay}"
                                          Margin="0,0,0,10" />

                                <CheckBox Content="触发时执行流程"
                                          IsChecked="{Binding RunFlowOnTrigger, Mode=TwoWay}"
                                          Margin="0,2,0,16" />

                                <UniformGrid Columns="2" Margin="0,0,0,18">
                                    <CheckBox Content="彩图转灰度图"
                                              IsChecked="{Binding ConvertColorToGray, Mode=TwoWay}"
                                              Margin="0,0,12,12" />
                                    <CheckBox Content="显示十字线"
                                              IsChecked="{Binding ShowCrosshair, Mode=TwoWay}"
                                              Margin="0,0,12,12" />
                                    <CheckBox Content="定义图像尺寸"
                                              IsChecked="{Binding DefineImageSize, Mode=TwoWay}"
                                              Margin="0,0,12,0" />
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding ToggleRealtimeCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="实时显示"
                                            MinWidth="92" />
                                    <Button Command="{Binding RunToolCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="采集一张"
                                            MinWidth="92" />
                                    <Button Command="{Binding SaveImageCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="图像另存"
                                            MinWidth="92"
                                            Margin="0" />
                                </StackPanel>

                                <Border Background="#AA0B1117"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10"
                                        Margin="0,14,0,0">
                                    <TextBlock Text="{Binding CameraDiagnosticsText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsFileSource, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="图像文件" Style="{StaticResource FormLabelStyle}" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             IsReadOnly="True"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Command="{Binding SelectImageFileCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="选择图片"
                                            MinWidth="88"
                                            Margin="0" />
                                </Grid>

                                <Border Background="#AA0B1117"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="12"
                                        Margin="0,0,0,16">
                                    <TextBlock Text="文件采集不会显示相机曝光、触发源和实时采集参数。选择图片后会立即加载到左侧预览区，运行工具会重新加载当前文件。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <UniformGrid Columns="2" Margin="0,0,0,18">
                                    <CheckBox Content="彩图转灰度图"
                                              IsChecked="{Binding ConvertColorToGray, Mode=TwoWay}"
                                              Margin="0,0,12,12" />
                                    <CheckBox Content="显示十字线"
                                              IsChecked="{Binding ShowCrosshair, Mode=TwoWay}"
                                              Margin="0,0,12,12" />
                                    <CheckBox Content="定义图像尺寸"
                                              IsChecked="{Binding DefineImageSize, Mode=TwoWay}"
                                              Margin="0,0,12,0" />
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding RunToolCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="{Binding PrimaryActionText}"
                                            MinWidth="104" />
                                    <Button Command="{Binding SaveImageCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="图像另存"
                                            MinWidth="92"
                                            Margin="0" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsDirectorySource, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="图像目录" Style="{StaticResource FormLabelStyle}" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Command="{Binding BrowseDirectoryCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="选择目录"
                                            MinWidth="88"
                                            Margin="0" />
                                </Grid>

                                <TextBlock Text="当前取图文件"
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,4,0,6" />
                                <TextBox Text="{Binding SelectedFilePath, Mode=OneWay}"
                                         IsReadOnly="True"
                                         Height="32"
                                         Margin="0,0,0,16" />

                                <Border Background="#AA0B1117"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="12"
                                        Margin="0,0,0,16">
                                    <TextBlock Text="目录采集会从目录中按文件名取第一张支持的图像。后续可以扩展为循环取图、按时间取图或按批次回放。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <UniformGrid Columns="2" Margin="0,0,0,18">
                                    <CheckBox Content="彩图转灰度图"
                                              IsChecked="{Binding ConvertColorToGray, Mode=TwoWay}"
                                              Margin="0,0,12,12" />
                                    <CheckBox Content="显示十字线"
                                              IsChecked="{Binding ShowCrosshair, Mode=TwoWay}"
                                              Margin="0,0,12,12" />
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding RunToolCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="{Binding PrimaryActionText}"
                                            MinWidth="104" />
                                    <Button Command="{Binding SaveImageCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="图像另存"
                                            MinWidth="92"
                                            Margin="0" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource AccentLineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ToggleButton Grid.Column="0"
                              IsChecked="{Binding IsRealtimeDisplayEnabled, Mode=TwoWay}"
                              Focusable="False"
                              IsHitTestVisible="False"
                              Style="{StaticResource SwitchToggleStyle}"
                              VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DurationText, Mode=OneWay, StringFormat=耗时：{0}}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding StatusText, Mode=OneWay, StringFormat=状态：{0}}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <CheckBox Grid.Column="2"
                          Content="启用变量图片输入"
                          IsChecked="{Binding EnableVariableImageInput, Mode=TwoWay}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,18,0" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RunToolCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="{Binding PrimaryActionText}"
                            MinWidth="92"
                            ToolTip="执行当前采图工具" />
                    <Button Command="{Binding RunFlowCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="运行流程"
                            MinWidth="92"
                            ToolTip="采图后返回并运行完整流程" />
                    <Button Command="{Binding CloseCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="关闭"
                            MinWidth="86"
                            ToolTip="保存参数并返回流程"
                            Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <controls:SimpleLoadingOverlay Grid.RowSpan="3"
                                       Panel.ZIndex="20"
                                       IsActive="{Binding IsBusy}" />
    </Grid>
</Window>
