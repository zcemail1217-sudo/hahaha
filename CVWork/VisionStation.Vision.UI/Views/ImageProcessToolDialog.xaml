<Window x:Class="VisionStation.Vision.UI.Views.ImageProcessToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:VisionStation.Vision.UI.Behaviors"
        xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls"
        xmlns:converters="clr-namespace:VisionStation.Vision.UI.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="1120"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="54"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImageFrameToBitmapSourceConverter x:Key="ImageFrameToBitmapSourceConverter" />
        <Style x:Key="DialogFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="DialogMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="NumericBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="86" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="58" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource IconTextStyle}" Text="{Binding HeaderIcon}" Width="26" />
                    <TextBlock Text="{Binding WindowTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="8,0,0,0"
                               MaxWidth="520" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="Minimize"
                            ToolTip="最小化">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE921;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="ToggleMaximize"
                            ToolTip="最大化/还原">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE922;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                            Command="{Binding CancelCommand}"
                            ToolTip="关闭">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8BB;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="Black"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="42" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="10,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE722;" FontSize="14" Width="18" />
                                <TextBlock Text="{Binding DisplayModeText}" FontWeight="SemiBold" Margin="6,0,0,0" />
                                <TextBlock Text="{Binding DurationText, StringFormat=  耗时：{0}}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="14,0,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Command="{Binding ShowInputImageCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="原图"
                                        MinWidth="58"
                                        Padding="8,4"
                                        Margin="0,0,6,0" />
                                <Button Command="{Binding ShowProcessedImageCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="结果"
                                        MinWidth="58"
                                        Padding="8,4"
                                        Margin="0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <controls:ZoomableImageSurface Grid.Row="1"
                                                   ImageFrame="{Binding PreviewDisplayFrame}"
                                                   Background="Black">
                        <Grid Background="Black">
                            <Image Source="{Binding PreviewDisplayFrame, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True" />
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="420"
                                    Padding="18,14"
                                    Background="#E60B1117"
                                    BorderBrush="{StaticResource WarnBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{Binding IsMissingInputImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    IsHitTestVisible="False">
                                <StackPanel>
                                    <TextBlock Text="未连接输入图像"
                                               Foreground="{StaticResource WarnBrush}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding MissingInputImageText}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </controls:ZoomableImageSurface>

                    <Border Grid.Row="2"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,1,0,0"
                            Padding="10,0">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="12,0,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="38" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" Style="{StaticResource DialogFieldLabelStyle}" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="3"
                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="类型" Style="{StaticResource DialogFieldLabelStyle}" />
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Height="30"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1"
                                Padding="10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ToolTypeText}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="启用" Style="{StaticResource DialogFieldLabelStyle}" Margin="16,0,10,0" />
                        <CheckBox Grid.Row="1" Grid.Column="3" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="调试图像" Style="{StaticResource DialogFieldLabelStyle}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Text="{Binding InputFrameInfo}"
                                   Style="{StaticResource DialogMutedTextStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasInputBindings, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="输入项" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding InputBindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="8,4"
                                                Background="{Binding SoftFill}"
                                                BorderBrush="{Binding Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Fill="{Binding Stroke}"
                                                         Margin="0,0,6,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding TargetName}" />
                                            </StackPanel>
                                        </Border>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding Options}"
                                                  SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                                  DisplayMemberPath="Name"
                                                  Height="30" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsThresholdOperation, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="阈值设置"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,12" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Height="28"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentLineBrush}"
                                BorderThickness="1"
                                Padding="10,0"
                                Margin="0,0,0,12">
                            <TextBlock Text="{Binding ThresholdModeHint}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="模式" Style="{StaticResource DialogFieldLabelStyle}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding ThresholdModes}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding ThresholdMode, Mode=TwoWay}"
                                  Height="30" />

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="目标极性" Style="{StaticResource DialogFieldLabelStyle}" Margin="16,0,10,0" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="3"
                                  ItemsSource="{Binding PolarityOptions}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding Polarity, Mode=TwoWay}"
                                  Height="30" />

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="4"
                              Margin="0,6,0,0"
                              Visibility="{Binding IsFixedMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="阈值" Style="{StaticResource DialogFieldLabelStyle}" />
                            <Slider Grid.Column="1"
                                    Minimum="0"
                                    Maximum="255"
                                    Value="{Binding Threshold, Mode=TwoWay}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource NumericBoxStyle}"
                                     Text="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="3"
                              Grid.ColumnSpan="4"
                              Margin="0,6,0,0"
                              Visibility="{Binding IsRangeMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="38" />
                                <RowDefinition Height="38" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="灰度下限" Style="{StaticResource DialogFieldLabelStyle}" />
                            <Slider Grid.Row="0"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="255"
                                    Value="{Binding GrayMin, Mode=TwoWay}"
                                    TickFrequency="1"
                                    VerticalAlignment="Center" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Style="{StaticResource NumericBoxStyle}"
                                     Text="{Binding GrayMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="灰度上限" Style="{StaticResource DialogFieldLabelStyle}" />
                            <Slider Grid.Row="1"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="255"
                                    Value="{Binding GrayMax, Mode=TwoWay}"
                                    TickFrequency="1"
                                    VerticalAlignment="Center" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="2"
                                     Style="{StaticResource NumericBoxStyle}"
                                     Text="{Binding GrayMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="4"
                              Grid.ColumnSpan="4"
                              Margin="0,6,0,0"
                              Visibility="{Binding IsAdaptiveMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="38" />
                                <RowDefinition Height="38" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="块大小" Style="{StaticResource DialogFieldLabelStyle}" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Style="{StaticResource NumericBoxStyle}"
                                     HorizontalAlignment="Left"
                                     Text="{Binding AdaptiveBlockSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="偏置 C" Style="{StaticResource DialogFieldLabelStyle}" Margin="16,0,10,0" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="3"
                                     Style="{StaticResource NumericBoxStyle}"
                                     HorizontalAlignment="Left"
                                     Text="{Binding AdaptiveC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="3"
                                       Text="块大小会自动取奇数，范围 3 - 501。"
                                       Style="{StaticResource DialogMutedTextStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsFilterOperation, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="滤波设置"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,12" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Height="28"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentLineBrush}"
                                BorderThickness="1"
                                Padding="10,0"
                                Margin="0,0,0,12">
                            <TextBlock Text="{Binding FilterModeHint}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="滤波类型" Style="{StaticResource DialogFieldLabelStyle}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding FilterTypes}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding FilterType, Mode=TwoWay}"
                                  Height="30" />

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="4"
                              Margin="0,6,0,0"
                              Visibility="{Binding UsesKernelSize, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="核大小" Style="{StaticResource DialogFieldLabelStyle}" />
                            <Slider Grid.Column="1"
                                    Minimum="1"
                                    Maximum="99"
                                    Value="{Binding KernelSize, Mode=TwoWay}"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource NumericBoxStyle}"
                                     Text="{Binding KernelSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="3"
                              Grid.ColumnSpan="4"
                              Margin="0,6,0,0"
                              Visibility="{Binding IsBilateralFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="38" />
                                <RowDefinition Height="38" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="颜色强度" Style="{StaticResource DialogFieldLabelStyle}" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Style="{StaticResource NumericBoxStyle}"
                                     HorizontalAlignment="Left"
                                     Text="{Binding SigmaColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="空间强度" Style="{StaticResource DialogFieldLabelStyle}" Margin="16,0,10,0" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="3"
                                     Style="{StaticResource NumericBoxStyle}"
                                     HorizontalAlignment="Left"
                                     Text="{Binding SigmaSpace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="3"
                                       Text="双边滤波会尽量保留边缘，参数越大降噪越强。"
                                       Style="{StaticResource DialogMutedTextStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsMorphologyOperation, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="42" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="形态学设置"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,12" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Height="28"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentLineBrush}"
                                BorderThickness="1"
                                Padding="10,0"
                                Margin="0,0,0,12">
                            <TextBlock Text="{Binding MorphologyModeHint}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="运算类型" Style="{StaticResource DialogFieldLabelStyle}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding MorphTypes}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding MorphType, Mode=TwoWay}"
                                  Height="30" />

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="结构元素" Style="{StaticResource DialogFieldLabelStyle}" Margin="16,0,10,0" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="3"
                                  ItemsSource="{Binding KernelShapes}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding KernelShape, Mode=TwoWay}"
                                  Height="30" />

                        <Grid Grid.Row="2" Grid.ColumnSpan="4" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="核大小" Style="{StaticResource DialogFieldLabelStyle}" />
                            <Slider Grid.Column="1"
                                    Minimum="1"
                                    Maximum="99"
                                    Value="{Binding KernelSize, Mode=TwoWay}"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource NumericBoxStyle}"
                                     Text="{Binding KernelSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="3" Grid.ColumnSpan="4" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="迭代次数" Style="{StaticResource DialogFieldLabelStyle}" />
                            <Slider Grid.Column="1"
                                    Minimum="1"
                                    Maximum="32"
                                    Value="{Binding Iterations, Mode=TwoWay}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource NumericBoxStyle}"
                                     Text="{Binding Iterations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Text="核大小会自动取奇数；开运算常用于去小亮点，闭运算常用于补小暗洞。"
                                   Style="{StaticResource DialogMutedTextStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}"
                        Visibility="{Binding HasOutputOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="输出项" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding OutputOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" Margin="0,0,10,8">
                                        <Border Padding="9,4"
                                                Background="{Binding SoftFill}"
                                                BorderBrush="{Binding Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Fill="{Binding Stroke}"
                                                         Margin="0,0,6,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" />
                                            </StackPanel>
                                        </Border>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding RunPreviewCommand}" Style="{StaticResource ActionButtonStyle}" MinWidth="96" ToolTip="使用当前参数生成处理结果预览">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE768;" Width="16" FontSize="12" />
                        <TextBlock Text="运行预览" Margin="4,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding CancelCommand}" Style="{StaticResource ActionButtonStyle}" Content="取消" MinWidth="88" ToolTip="放弃本次修改" />
                <Button Command="{Binding ConfirmCommand}" Style="{StaticResource ActionButtonStyle}" Content="确定" MinWidth="88" ToolTip="应用参数并关闭" Margin="0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
