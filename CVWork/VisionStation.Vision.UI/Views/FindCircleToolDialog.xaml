<Window x:Class="VisionStation.Vision.UI.Views.FindCircleToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:VisionStation.Vision.UI.Behaviors"
        xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls"
        xmlns:converters="clr-namespace:VisionStation.Vision.UI.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="740"
        MinWidth="1040"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ImageFrameToBitmapSourceConverter x:Key="ImageFrameToBitmapSourceConverter" />

        <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="CircleTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="58" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,0,1">
            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RunToolCommand}" Style="{StaticResource HeaderIconButtonStyle}" ToolTip="运行找圆">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE768;" FontSize="15" />
                    </Button>
                    <Button Command="{Binding EditCaliperCommand}" Style="{StaticResource HeaderIconButtonStyle}" ToolTip="编辑圆卡尺">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xEA3A;" FontSize="15" />
                    </Button>
                    <Button Command="{Binding CloseCommand}" Style="{StaticResource HeaderIconButtonStyle}" ToolTip="返回流程">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE72B;" FontSize="15" />
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding WindowTitle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="启用"
                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                              Margin="0,0,14,0"
                              VerticalAlignment="Center"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="Minimize"
                            ToolTip="最小化">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE921;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            behaviors:WindowCaptionActionBehavior.Action="ToggleMaximize"
                            ToolTip="最大化/还原">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE922;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                            Command="{Binding CloseCommand}"
                            ToolTip="关闭">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8BB;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="560" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="Black"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <controls:ZoomableImageSurface ImageFrame="{Binding CurrentFrame}"
                                               OverlayItemsSource="{Binding PreviewOverlays}"
                                               Background="Black">
                    <Grid Background="Black">
                        <Image Source="{Binding CurrentFrame, Converter={StaticResource ImageFrameToBitmapSourceConverter}}"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True" />
                        <controls:ResultOverlayCanvas ImageFrame="{Binding CurrentFrame}"
                                                      ItemsSource="{Binding PreviewOverlays}"
                                                      IsHitTestVisible="False" />
                        <controls:RoiEditorCanvas ImageFrame="{Binding CurrentFrame}"
                                                  ItemsSource="{Binding EditableRois}"
                                                  SelectedRoi="{Binding SelectedEditableRoi, Mode=TwoWay}"
                                                  PlacementCommand="{Binding PlaceRoiCommand}"
                                                  IsPlacementArmed="{Binding IsRoiPlacementArmed}"
                                                  Focusable="True" />
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,12,0,0"
                                Padding="12,7"
                                Background="#DD0B1117"
                                BorderBrush="{StaticResource AccentLineBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsRoiPlacementArmed, Converter={StaticResource BooleanToVisibilityConverter}}"
                                IsHitTestVisible="False">
                            <TextBlock Text="{Binding RoiPlacementHint}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Grid Visibility="{Binding ShowCrosshair, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False">
                            <Border Width="1" Background="{StaticResource AccentLineBrush}" HorizontalAlignment="Center" />
                            <Border Height="1" Background="{StaticResource AccentLineBrush}" VerticalAlignment="Center" />
                        </Grid>
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420"
                                Padding="18,14"
                                Background="#E60B1117"
                                BorderBrush="{StaticResource WarnBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsMissingInputImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                IsHitTestVisible="False">
                            <StackPanel>
                                <TextBlock Text="未连接输入图像"
                                           Foreground="{StaticResource WarnBrush}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding MissingInputImageText}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </controls:ZoomableImageSurface>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding Title}"
                                            Style="{StaticResource CircleTabButtonStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Grid Grid.Row="1" Margin="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsHomeTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,18,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="214" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="44" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="38" />
                                            <RowDefinition Height="42" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Row="0"
                                                Grid.ColumnSpan="2"
                                                Command="{Binding EditCaliperCommand}"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Content="编辑圆卡尺"
                                                MinWidth="104"
                                                HorizontalAlignment="Left"
                                                Padding="14,7" />
                                        <TextBlock Grid.Row="1" Text="最小分数" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinScore, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Height="28" />
                                        <TextBlock Grid.Row="2" Text="卡尺数" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CaliperCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Height="28" />
                                        <TextBlock Grid.Row="3" Text="阈值" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EdgeThreshold, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Height="28" />
                                        <TextBlock Grid.Row="4" Text="极性" Style="{StaticResource FormLabelStyle}" />
                                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Polarities}" SelectedItem="{Binding Polarity, Mode=TwoWay}" Height="28" />
                                        <TextBlock Grid.Row="5" Text="搜索方向" Style="{StaticResource FormLabelStyle}" />
                                        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding SearchDirections}" SelectedItem="{Binding SearchDirection, Mode=TwoWay}" Height="28" />
                                        <TextBlock Grid.Row="6" Text="结果选择" Style="{StaticResource FormLabelStyle}" />
                                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding ResultSelections}" SelectedItem="{Binding ResultSelection, Mode=TwoWay}" Height="28" />
                                        <TextBlock Grid.Row="7" Text="卡尺宽度" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CaliperWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Height="28" />
                                        <TextBlock Grid.Row="8" Text="搜索宽度" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SearchWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Height="28" />
                                        <TextBlock Grid.Row="9" Text="工具名称" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" />
                                    </Grid>

                                    <Border Grid.Column="1"
                                            Margin="18,26,0,0"
                                            MinWidth="260"
                                            BorderBrush="{StaticResource BorderBrushStrong}"
                                            BorderThickness="1"
                                            Background="#AA0B1117"
                                            Padding="14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="34" />
                                                <RowDefinition Height="32" />
                                                <RowDefinition Height="32" />
                                                <RowDefinition Height="32" />
                                                <RowDefinition Height="32" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="102" />
                                                <ColumnDefinition Width="150" MinWidth="150" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="结果圆" FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="1" Text="圆心行坐标" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CenterRowText, Mode=OneWay}" IsReadOnly="True" Height="26" HorizontalContentAlignment="Right" />
                                            <TextBlock Grid.Row="2" Text="圆心列坐标" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CenterColumnText, Mode=OneWay}" IsReadOnly="True" Height="26" HorizontalContentAlignment="Right" />
                                            <TextBlock Grid.Row="3" Text="半径" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RadiusText, Mode=OneWay}" IsReadOnly="True" Height="26" HorizontalContentAlignment="Right" />
                                            <TextBlock Grid.Row="4" Text="分数" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ScoreText, Mode=OneWay}" IsReadOnly="True" Height="26" HorizontalContentAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="1"
                                        Margin="0,0,0,18"
                                        Padding="10,8"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        Background="{StaticResource SurfaceAltBrush}">
                                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                </Border>

                                <Button Grid.Row="2"
                                        Command="{Binding RunToolCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="运行"
                                        MinWidth="118"
                                        MinHeight="42"
                                        Padding="22,8"
                                        HorizontalAlignment="Right" />
                            </Grid>
                        </ScrollViewer>

                        <StackPanel Visibility="{Binding IsDisplayTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Background="{StaticResource SurfaceAltBrush}" Padding="8,5" Margin="0,0,0,12">
                                <TextBlock Text="显示" FontWeight="SemiBold" />
                            </Border>
                            <CheckBox Content="显示十字线" IsChecked="{Binding ShowCrosshair, Mode=TwoWay}" Margin="4,0,0,10" />
                        </StackPanel>

                        <ScrollViewer Visibility="{Binding IsOutputTab, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Background="{StaticResource SurfaceAltBrush}" Padding="8,5" Margin="0,0,0,12">
                                    <TextBlock Text="输出项" FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="选择当前工具对外暴露的输出端口。未勾选的输出不会参与后续工具连接和参数保存。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />
                                <ItemsControl ItemsSource="{Binding OutputOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      Margin="0,0,0,10">
                                                <Border Padding="12,9"
                                                        Background="{Binding SoftFill}"
                                                        BorderBrush="{Binding Stroke}"
                                                        BorderThickness="1"
                                                        CornerRadius="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="10"
                                                                 Height="10"
                                                                 Fill="{Binding Stroke}"
                                                                 Margin="0,0,10,0"
                                                                 VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding DataType}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,1,0,0"
                Padding="14,0">
            <Grid>
                <TextBlock Text="{Binding InputFrameInfo}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DurationText, StringFormat=耗时：{0}}" Margin="0,0,18,0" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding RunFlowCommand}" Style="{StaticResource ActionButtonStyle}" Content="运行流程" MinWidth="92" />
                    <Button Command="{Binding CloseCommand}" Style="{StaticResource ActionButtonStyle}" Content="关闭" MinWidth="86" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <controls:SimpleLoadingOverlay Grid.RowSpan="3"
                                       Panel.ZIndex="20"
                                       IsActive="{Binding IsBusy}" />
    </Grid>
</Window>
