<UserControl x:Class="VisionStation.Devices.UI.Views.DeviceStatusView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             Foreground="{StaticResource TextPrimaryBrush}"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <Style x:Key="StatusChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF111B23" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>

        <Style x:Key="WorkspaceTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AxisChannelButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="86" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FF101922" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Border x:Name="AccentRail"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Background="#FF2C3B44"
                                        CornerRadius="4,0,0,4" />
                                <ContentPresenter Margin="16,10,12,10"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF14232C" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF12352F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="AccentRail" Property="Background" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadoutBlockStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF091119" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <Style x:Key="LampBlockStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF0D151C" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="54" />
        </Style>

        <Style x:Key="ConsoleGroupStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF0B141C" />
            <Setter Property="BorderBrush" Value="#FF263944" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="ConsoleGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="ConsoleButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="JogButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#FF11312B" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="MinHeight" Value="44" />
        </Style>

        <Style x:Key="EmergencyConsoleButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#552A1018" />
            <Setter Property="BorderBrush" Value="{StaticResource NgBrush}" />
            <Setter Property="MinHeight" Value="58" />
        </Style>

        <Style x:Key="IoTileStyle" TargetType="Border">
            <Setter Property="Width" Value="176" />
            <Setter Property="MinHeight" Value="98" />
            <Setter Property="Background" Value="#FF101A22" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="#FF101A22" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Root"
                                    Margin="0,0,1,0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Border x:Name="RightEdge"
                                    Width="1"
                                    Margin="0,4,0,4"
                                    HorizontalAlignment="Right"
                                    Background="{TemplateBinding BorderBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                                <Setter TargetName="RightEdge" Property="Background" Value="{StaticResource AccentLineBrush}" />
                                <Setter Property="Background" Value="#FF14232C" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="1" />
                                <Setter Property="Background" Value="#FF12352F" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="RightEdge" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="ConfigurationDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="66" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="36"
                        Height="36"
                        Background="#2633D6A6"
                        BorderBrush="{StaticResource AccentLineBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock Style="{StaticResource IconTextStyle}"
                               Text="&#xE950;"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="{Binding WorkbenchTitle}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding WorkbenchSubtitle}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel Width="132" Margin="0,0,10,0">
                    <TextBlock Text="调试类型" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding DebugModeOptions}"
                              SelectedValue="{Binding DebugMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Text"
                              MinHeight="32" />
                </StackPanel>
                <Button Command="{Binding ShowDebugWorkspaceCommand}"
                        Style="{StaticResource WorkspaceTabButtonStyle}"
                        Background="{Binding DebugTabBackground}"
                        BorderBrush="{Binding DebugTabBorderBrush}">
                    <TextBlock Text="调试台" FontWeight="SemiBold" />
                </Button>
                <Button Command="{Binding ShowConfigurationWorkspaceCommand}"
                        Style="{StaticResource WorkspaceTabButtonStyle}"
                        Background="{Binding ConfigurationTabBackground}"
                        BorderBrush="{Binding ConfigurationTabBorderBrush}">
                    <TextBlock Text="轴卡配置" FontWeight="SemiBold" />
                </Button>
                <Border Style="{StaticResource StatusChipStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE945;" Width="18" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding AxisDriverSummaryText}" Margin="6,0,0,0" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Button Command="{Binding ConnectAllCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="连接轴卡和 IO">
                    <TextBlock Text="连接轴卡 / IO" />
                </Button>
                <Button Command="{Binding EmergencyStopCommand}"
                        Background="#553B1018"
                        BorderBrush="{StaticResource NgBrush}"
                        Style="{StaticResource ActionButtonStyle}"
                        ToolTip="立即停止所有轴">
                    <TextBlock Text="急停 E-STOP" Foreground="{StaticResource NgBrush}" FontWeight="SemiBold" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Visibility="{Binding AxisDebugWorkspaceVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="292" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="560" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE9D9;" Width="24" />
                            <TextBlock Text="轴通道" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding AxisSoftLimitText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="32,6,0,0" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Axes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource AxisChannelButtonStyle}"
                                            Command="{Binding DataContext.SelectAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <TextBlock Text="{Binding ChannelText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Key}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" Margin="0,8,0,0" />
                                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding SoftLimitText}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding ProfileText}" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                                            </Grid>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="104" />
                        <RowDefinition Height="58" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.ColumnSpan="3"
                                    Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE768;" Width="24" />
                            <TextBlock Text="运动控制台" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding SelectedAxisTitle}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="32,5,0,0"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="{Binding AxisStatusText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="360" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ReadoutBlockStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="2" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock Text="反馈" DockPanel.Dock="Right" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="ENCODER POSITION / 反馈位置" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                </DockPanel>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AxisEncoderText}"
                                           FontFamily="Consolas"
                                           FontSize="34"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Grid.Row="2" Background="{StaticResource AccentLineBrush}" Opacity="0.8" />
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource ReadoutBlockStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="2" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock Text="指令" DockPanel.Dock="Right" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="COMMAND POSITION / 指令位置" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                </DockPanel>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AxisCommandText}"
                                           FontFamily="Consolas"
                                           FontSize="34"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border Grid.Row="2" Background="{StaticResource AccentLineBrush}" Opacity="0.8" />
                            </Grid>
                        </Border>
                    </Grid>

                    <UniformGrid Grid.Row="2" Columns="7">
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisServoBrush}" Margin="0,0,8,0" ToolTip="SERVO / 伺服使能">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisServoBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="伺服" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisServoText}" Foreground="{Binding AxisServoBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisReadyBrush}" Margin="0,0,8,0" ToolTip="READY / 轴就绪">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisReadyBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="就绪" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisReadyText}" Foreground="{Binding AxisReadyBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisInPositionBrush}" Margin="0,0,8,0" ToolTip="IN-POS / 轴到位">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisInPositionBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="到位" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisInPositionText}" Foreground="{Binding AxisInPositionBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisAlarmBrush}" Margin="0,0,8,0" ToolTip="ALARM / 轴报警">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisAlarmBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="报警" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisAlarmText}" Foreground="{Binding AxisAlarmBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisHomeBrush}" Margin="0,0,8,0" ToolTip="HOME / 原点信号">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisHomeBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="原点" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisHomeText}" Foreground="{Binding AxisHomeBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisPositiveLimitBrush}" Margin="0,0,8,0" ToolTip="+LIMIT / 正限位">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisPositiveLimitBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="正限位" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisPositiveLimitText}" Foreground="{Binding AxisPositiveLimitBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource LampBlockStyle}" BorderBrush="{Binding AxisNegativeLimitBrush}" ToolTip="-LIMIT / 负限位">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9" Height="9" Fill="{Binding AxisNegativeLimitBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="负限位" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AxisNegativeLimitText}" Foreground="{Binding AxisNegativeLimitBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="276" />
                        </Grid.ColumnDefinitions>

                        <TabControl Grid.Column="0" Background="Transparent" BorderThickness="0">
                            <TabItem Header="点位模式">
                                <Border Style="{StaticResource ConsoleGroupStyle}" Margin="0,10,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="46" />
                                            <RowDefinition Height="20" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="目标位置" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox Text="{Binding AxisTargetPosition, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" Padding="12,8" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="速度" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox Text="{Binding AxisSpeed, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" Padding="12,8" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="加速度" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox Text="{Binding AxisAcceleration, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" Padding="12,8" />
                                            </StackPanel>
                                        </Grid>

                                        <Button Grid.Row="2" Command="{Binding MoveAxisCommand}" Style="{StaticResource ConsoleButtonStyle}" HorizontalAlignment="Stretch">
                                            <TextBlock Text="绝对移动" />
                                        </Button>

                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
