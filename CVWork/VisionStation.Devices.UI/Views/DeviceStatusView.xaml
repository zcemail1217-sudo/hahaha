                                                    <TextBlock Text="{Binding ToggleText}" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>

                    <TextBlock Grid.Row="2"
                               Text="{Binding IoStatusText}"
