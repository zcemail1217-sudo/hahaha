                                                    <TextBlock Text="{Binding ValueText}"
                                                               Foreground="{Binding StateBrush}"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="极性" Binding="{Binding PolarityText}" Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="DO 输出点">
