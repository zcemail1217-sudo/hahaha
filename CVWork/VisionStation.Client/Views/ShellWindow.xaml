<Window x:Class="VisionStation.Client.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:VisionStation.Vision.UI.Behaviors;assembly=VisionStation.Vision.UI"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="VisionStation"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        behaviors:WindowWorkAreaMaximizeBehavior.UseWorkArea="True"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NgBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFD94B60" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivityButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent"
                              ClipToBounds="False">
                            <Border x:Name="SelectedPlate"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <Border x:Name="HoverPlate"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#221FDAC2"
                                    BorderBrush="#5533D6A6"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="HoverPlateScale"
                                                    ScaleX="0.78"
                                                    ScaleY="0.78" />
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="ActiveBar"
                                    Width="3"
                                    Height="22"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="0,2,2,0"
                                    Opacity="0" />
                            <ContentPresenter x:Name="IconHost"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="IconScale"
                                                    ScaleX="1"
                                                    ScaleY="1" />
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverPlate"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.14" />
                                            <DoubleAnimation Storyboard.TargetName="HoverPlateScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="HoverPlateScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="IconScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.11"
                                                             Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="IconScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.11"
                                                             Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverPlate"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="HoverPlateScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.78"
                                                             Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="HoverPlateScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.78"
                                                             Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="IconScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="IconScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SelectedPlate" Property="Opacity" Value="1" />
                                <Setter TargetName="ActiveBar" Property="Opacity" Value="1" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>

        <Style x:Key="GlobalSaveButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="124" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="13,5" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource WindowBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AlarmToastIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#BB0B1117" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF1B3D40" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlarmDialogActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#CC0B1117" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF1B3D40" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource ActivityBarBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Border Width="22"
                            Height="22"
                            CornerRadius="5"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentLineBrush}"
                            BorderThickness="1">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE950;" FontSize="13" />
                    </Border>
                    <TextBlock Text="VisionStation"
                               Margin="9,0,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="视觉检测工作站"
                               Margin="12,0,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding PageTitle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="最小化">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE921;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button x:Name="MaximizeRestoreButton"
                            Style="{StaticResource CaptionButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="最大化/还原">
                        <TextBlock x:Name="MaximizeRestoreIcon" Style="{StaticResource IconTextStyle}" Text="&#xE922;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="关闭">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8BB;" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.RowSpan="3"
                Grid.Column="0"
                Background="{StaticResource ActivityBarBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="124" />
                </Grid.RowDefinitions>

                <Border Width="38"
                        Height="38"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="7"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource AccentLineBrush}"
                        BorderThickness="1">
                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE950;" FontSize="20" />
                </Border>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ActivityButtonStyle}"
                                    ToolTip="{Binding Title}"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Key}">
                                <TextBlock Style="{StaticResource IconTextStyle}"
                                           Text="{Binding Icon}"
                                           FontSize="21"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding UtilityNavigationItems}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ActivityButtonStyle}"
                                    ToolTip="{Binding Title}"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Key}">
                                <TextBlock Style="{StaticResource IconTextStyle}"
                                           Text="{Binding Icon}"
                                           FontSize="21"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="VisionStation"
                               Margin="14,0,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource GlobalSaveButtonStyle}"
                        Command="{Binding GlobalSave.SaveAllCommand}"
                        ToolTip="{Binding GlobalSave.SaveAllToolTip}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource IconTextStyle}"
                                   Text="&#xE74E;"
                                   FontSize="13"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <TextBlock Text="{Binding GlobalSave.SaveAllButtonText}"
                                   Margin="7,0,0,0"
                                   TextTrimming="None"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Row="2"
                        Grid.Column="1"
                        Margin="10"
                        prism:RegionManager.RegionName="MainRegion" />

        <Border Grid.Row="3"
                Grid.Column="1"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,1,0,0"
                Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding DeviceStatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="生产" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding ProductionStateText}" Foreground="{Binding ProductionStateBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="相机" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding CameraStateText}" Foreground="{Binding CameraStateBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="PLC" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding PlcStateText}" Foreground="{Binding PlcStateBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="轴" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding AxisStateText}" Foreground="{Binding AxisStateBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="报警" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding AlarmStatusText}" Foreground="{Binding AlarmStatusBrush}" Margin="0,0,12,0" />
                    <Border Width="1"
                            Height="14"
                            Background="{StaticResource BorderBrushStrong}"
                            Margin="0,0,12,0" />
                    <TextBlock Text="{Binding ClockText}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Grid.RowSpan="4"
                      Grid.ColumnSpan="2"
                      Panel.ZIndex="80"
                      ItemsSource="{Binding AlarmToasts}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="32">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="620"
                            MaxWidth="620"
                            MinHeight="230"
                            Margin="0,0,0,14"
                            Padding="0"
                            Background="#F20B1117"
                            BorderBrush="{Binding AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="7">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="68" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="58" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{Binding SoftBrush}"
                                    BorderBrush="{Binding AccentBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="18,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="38"
                                            Height="38"
                                            CornerRadius="6"
                                            Background="#CC0B1117"
                                            BorderBrush="{Binding AccentBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource IconTextStyle}"
                                                   Text="{Binding Icon}"
                                                   FontSize="20"
                                                   Foreground="{Binding AccentBrush}" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <TextBlock Text="{Binding DialogTitle}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding AccentBrush}"
                                                   TextTrimming="None" />
                                        <TextBlock Text="{Binding SeverityText}"
                                                   Margin="0,3,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TimeText}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="16"
                                               TextTrimming="None" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="22,18,22,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="来源"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Width="54"
                                               TextTrimming="None" />
                                    <TextBlock Text="{Binding Source}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               TextTrimming="None" />
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Margin="0,14,0,0"
                                        Padding="14"
                                        Background="#AA101820"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="17"
                                               LineHeight="26"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </Border>
                            </Grid>

                            <Border Grid.Row="2"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,0">
                                <Grid>
                                    <TextBlock Text="报警已写入系统日志"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="None" />

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource AlarmDialogActionButtonStyle}"
                                                Visibility="{Binding HideButtonVisibility}"
                                                Command="{Binding DataContext.HideAlarmToastCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                ToolTip="暂时隐藏">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource IconTextStyle}"
                                                           Text="&#xE711;"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <TextBlock Text="隐藏"
                                                           Margin="7,0,0,0"
                                                           TextTrimming="None" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource AlarmDialogActionButtonStyle}"
                                                Command="{Binding DataContext.ConfirmAlarmCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                ToolTip="{Binding ActionText}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource IconTextStyle}"
                                                           Text="&#xE73E;"
                                                           FontSize="14"
                                                           Foreground="{Binding AccentBrush}" />
                                                <TextBlock Text="{Binding ActionText}"
                                                           Margin="7,0,0,0"
                                                           TextTrimming="None" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
