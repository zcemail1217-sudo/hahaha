<Window x:Class="VisionStation.Client.Views.UnsavedChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="存在未保存修改"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="{StaticResource WorkbenchBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="52"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="UnsavedDialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.74" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource DisabledSurfaceBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveAndCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource UnsavedDialogButtonStyle}">
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource WindowBrush}" />
        </Style>

        <Style x:Key="CloseWithoutSavingButtonStyle" TargetType="Button" BasedOn="{StaticResource UnsavedDialogButtonStyle}">
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Background" Value="{StaticResource NgSoftBrush}" />
            <Setter Property="BorderBrush" Value="#80FF667A" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WorkbenchBrush}"
            BorderBrush="{StaticResource AccentLineBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelHeaderBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="0,0,0,1"
                    Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="28"
                            Height="28"
                            CornerRadius="4"
                            Background="{StaticResource WarnSoftBrush}"
                            BorderBrush="{StaticResource WarnBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Text="!"
                                   Foreground="{StaticResource WarnBrush}"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextTrimming="None" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="11,0,0,0">
                        <TextBlock Text="存在未保存修改"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   TextTrimming="None" />
                        <TextBlock Text="关闭软件前，请选择如何处理这些项目内容"
                                   Margin="0,2,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   TextTrimming="None" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="34"
                            Height="34"
                            Style="{StaticResource CaptionButtonStyle}"
                            Click="Cancel_Click"
                            ToolTip="取消关闭">
                        <TextBlock Style="{StaticResource IconTextStyle}"
                                   Text="&#xE8BB;"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18,16,18,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="以下内容还没有保存："
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="None" />

                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <ScrollViewer MaxHeight="220"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12,10"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderBrushStrong}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Background="{StaticResource WarnBrush}"
                                                    CornerRadius="2" />

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Margin="0,4,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="None">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelHeaderBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                <Grid>
                    <TextBlock Text="选择“不保存关闭”将丢失这些修改"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="None" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="保存并关闭"
                                Style="{StaticResource SaveAndCloseButtonStyle}"
                                IsDefault="True"
                                Click="SaveAndClose_Click" />
                        <Button Content="不保存关闭"
                                Style="{StaticResource CloseWithoutSavingButtonStyle}"
                                Click="CloseWithoutSaving_Click" />
                        <Button Content="取消"
                                MinWidth="82"
                                Style="{StaticResource UnsavedDialogButtonStyle}"
                                IsCancel="True"
                                Click="Cancel_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
