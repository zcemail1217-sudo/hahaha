<UserControl x:Class="VisionStation.Client.Views.SystemLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="{StaticResource WorkbenchBrush}">
        <Border Style="{StaticResource PanelBorderStyle}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8A5;" Width="30" />
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="系统日志" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="最近 200 条运行事件" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            <ListBox ItemsSource="{Binding Logs}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4"
                              ToolTip="{Binding Message}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Time}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding LevelText}" Foreground="{Binding LevelBrush}" />
                            <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Message}"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       LineHeight="20" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
