<Window x:Class="VisionStation.Client.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls;assembly=VisionStation.Vision.UI"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="VisionStation Startup"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Background="{StaticResource WindowBrush}">
        <controls:TechLoadingOverlay IsActive="True"
                                     Message="{Binding LoadingMessage}"
                                     Detail="{Binding LoadingDetail}"
                                     StepsSource="{Binding LoadingStages}"
                                     MinimumVisibleMilliseconds="0" />
    </Grid>
</Window>
