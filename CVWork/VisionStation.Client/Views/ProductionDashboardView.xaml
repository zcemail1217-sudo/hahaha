<UserControl x:Class="VisionStation.Client.Views.ProductionDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls;assembly=VisionStation.Vision.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <Style x:Key="PanelTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#CC0B1117" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="9,5" />
        </Style>

        <Style x:Key="OutcomeBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="23" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="640" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="0"
                Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelHeaderBrush}"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="0,0,0,1"
                        Padding="14,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE722;" Width="26" FontSize="17" />
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="检测窗口" Style="{StaticResource PanelTitleTextStyle}" />
                                <TextBlock Text="{Binding FlowPanelSubtitle}" Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Command="{Binding RunSingleCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="触发一次完整检测">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE768;" Width="18" FontSize="13" />
                                    <TextBlock Text="单次检测" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StartCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="启动连续检测循环">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE102;" Width="18" FontSize="13" Foreground="{StaticResource OkBrush}" />
                                    <TextBlock Text="连续生产" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StopCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="停止连续检测循环">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE71A;" Width="18" FontSize="13" Foreground="{StaticResource NgBrush}" />
                                    <TextBlock Text="停止" Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding DisplayPanes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding DataContext.DisplayColumnCount, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PanelBorderStyle}"
                                    Padding="0"
                                    Margin="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="42" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="{StaticResource PanelHeaderBrush}"
                                            BorderBrush="{StaticResource BorderBrushStrong}"
                                            BorderThickness="0,0,0,1"
                                            Padding="10,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid VerticalAlignment="Center" Margin="0,0,8,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Style="{StaticResource IconTextStyle}" Text="&#xE722;" Width="22" FontSize="14" />
                                                <TextBlock Text="{Binding Title}"
                                                           Grid.Column="1"
                                                           Margin="8,0,0,0"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedFlow.FlowName, TargetNullValue=未绑定流程}"
                                                           Grid.Column="2"
                                                           Margin="12,0,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding LastBarcode, StringFormat=条码 {0}}"
                                                           Grid.Column="3"
                                                           Margin="12,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding LastMessage}"
                                                           Grid.Column="4"
                                                           Margin="12,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <controls:VisionResultDisplayControl Grid.Row="1"
                                                                         ImageFrame="{Binding CurrentFrame}"
                                                                         OverlayItemsSource="{Binding Overlays}"
                                                                         HasResult="{Binding HasResult}"
                                                                         ResultText="{Binding LastOutcome}"
                                                                         ResultBrush="{Binding LastOutcomeBrush}"
                                                                         ShowIdleState="False"
                                                                         ShowToolbar="True"
                                                                         ShowPixelInfo="True"
                                                                         ShowZoomInfo="True" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="236" />
                <RowDefinition Height="*" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="0"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="96" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBadgeStyle}" Width="42" Height="42">
                                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8FB;" FontSize="20" Foreground="{Binding LastOutcomeBrush}" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <TextBlock Text="综合判定" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding LastOutcome}"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{Binding LastOutcomeBrush}" />
                                <TextBlock Text="{Binding LastResultSummary}"
                                           Margin="0,4,0,0"
                                           MaxWidth="180"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           ToolTip="{Binding LastResultSummary}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="条码" Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding LastBarcode}"
                                           Margin="0,4,0,0"
                                           MaxWidth="150"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="14,12,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="0,0,1,1"
                                Padding="0,0,12,10">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="检测总数" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding TotalCount}" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="0,0,0,1"
                                Padding="12,0,0,10">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="OK / NG" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold">
                                    <Run Text="{Binding OkCount, Mode=OneWay}" Foreground="{StaticResource OkBrush}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding NgCount, Mode=OneWay}" Foreground="{StaticResource NgBrush}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="0,0,1,0"
                                Padding="0,10,12,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="良率" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding YieldText}" Style="{StaticResource MetricValueStyle}" Foreground="{StaticResource OkBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Padding="12,10,0,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="节拍" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding CycleTimeText}" Style="{StaticResource MetricValueStyle}" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="0"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE81C;" Width="24" FontSize="16" />
                            <TextBlock Text="最近检测" Style="{StaticResource PanelTitleTextStyle}" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="30"
                              ColumnHeaderHeight="30">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="74" />
                            <DataGridTemplateColumn Header="结果" Width="78">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource OutcomeBadgeStyle}"
                                                Background="{Binding OutcomeSoftBrush}"
                                                BorderBrush="{Binding OutcomeBrush}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource IconTextStyle}"
                                                           Text="{Binding OutcomeIcon}"
                                                           Width="15"
                                                           FontSize="10"
                                                           Foreground="{Binding OutcomeBrush}" />
                                                <TextBlock Text="{Binding OutcomeText}"
                                                           Margin="4,0,0,0"
                                                           Foreground="{Binding OutcomeBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="节拍" Binding="{Binding CycleTime}" Width="74" />
                            <DataGridTextColumn Header="条码" Binding="{Binding Barcode}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8A5;" Width="24" FontSize="16" />
                            <TextBlock Text="运行日志" Style="{StaticResource PanelTitleTextStyle}" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Logs}"
                             BorderThickness="0"
                             Padding="10,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,7"
                                      ToolTip="{Binding Message}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Time, Mode=OneWay}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LevelText, Mode=OneWay}"
                                               FontSize="12"
                                               Foreground="{Binding LevelBrush}"
                                               VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message, Mode=OneWay}"
                                               FontSize="12"
                                               LineHeight="18"
                                               TextWrapping="Wrap"
                                               TextTrimming="None" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <controls:SimpleLoadingOverlay Grid.ColumnSpan="2"
                                       Panel.ZIndex="20"
                                       IsActive="{Binding IsBusy}" />
    </Grid>
</UserControl>
