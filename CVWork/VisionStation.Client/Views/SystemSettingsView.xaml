                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE722;" Width="28" />
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="检测窗口配置" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding DashboardLayoutStatusText}"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding AddDashboardPaneCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="新增一个主页面检测显示窗口">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE710;" Width="18" />
                                        <TextBlock Text="添加窗口" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding RemoveDashboardPaneCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="移除当前选中的检测窗口">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE711;" Width="18" />
                                        <TextBlock Text="移除窗口" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Padding="14">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="配置后点击右上角“保存设置”生效。主页面只负责显示这里配置好的窗口。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,10" />

                            <DataGrid ItemsSource="{Binding DashboardPanes}"
                                      SelectedItem="{Binding SelectedDashboardPane}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="窗口" Binding="{Binding Title}" IsReadOnly="True" Width="140" />
                                    <DataGridTemplateColumn Header="绑定视觉流程" Width="320">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.DashboardFlowOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          SelectedItem="{Binding SelectedFlow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          DisplayMemberPath="FlowName"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="流程ID" Binding="{Binding BoundFlowId}" IsReadOnly="True" Width="220" />
                                    <DataGridTextColumn Header="说明" Binding="{Binding FlowName}" IsReadOnly="True" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
