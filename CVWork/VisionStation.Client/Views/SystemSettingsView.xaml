<UserControl x:Class="VisionStation.Client.Views.SystemSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <Style x:Key="SettingsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0"
                                      IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="0,0,0,12" />
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Border x:Name="SelectedLine"
                                    Height="2"
                                    Margin="9,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Bottom"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="1"
                                    Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF14232C" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                                <Setter TargetName="SelectedLine" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="ReadoutBlockStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF091119" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <Style x:Key="ConsoleButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE713;" Width="28" />
                <StackPanel Margin="8,0,0,0">
                    <TextBlock Text="系统设置" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="MES、PLC、运行参数" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding ReloadSettingsCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="从配置文件重新载入">
                    <TextBlock Text="重新载入" />
                </Button>
                <Button Command="{Binding SaveSettingsCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="保存系统设置">
                    <TextBlock Text="保存设置" />
                </Button>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1"
                    Style="{StaticResource SettingsTabControlStyle}"
                    ItemContainerStyle="{StaticResource SettingsTabItemStyle}">
            <TabItem Header="运行参数">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="360" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE774;" Width="24" />
                            <TextBlock Text="MES上传固定信息" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                        </StackPanel>

                        <UniformGrid Columns="2" Rows="5">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="启用上传" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <CheckBox IsChecked="{Binding MesUploadEnabled}" Content="MES上传" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="上传模式" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesUploadMode, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="产线编码" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesLineCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="工站编码" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesStationCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="设备编码" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesEquipmentCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="工序编码" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesProcessCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="产品编码" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesProductCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="接口令牌" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesApiToken, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,0">
                                <TextBlock Text="MES接口地址" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MesEndpoint, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                        </UniformGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="14">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE950;" Width="24" />
                            <TextBlock Text="PLC通讯参数" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                        </StackPanel>

                        <UniformGrid Columns="2" Rows="4">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="协议" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcProtocol, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="PLC IP地址" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcIpAddress, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="端口" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcPort, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="站号" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcStationNo, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="连接超时(ms)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcConnectTimeoutMs, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="心跳周期(ms)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcHeartbeatIntervalMs, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="心跳地址" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcHeartbeatAddress, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="结果地址" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PlcResultAddress, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                            </StackPanel>
                        </UniformGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource PanelBorderStyle}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="设备名称" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                            <TextBox Text="{Binding MachineName, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="检测超时(ms)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                            <TextBox Text="{Binding InspectionTimeoutMs, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="图像保留天数" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                            <TextBox Text="{Binding ImageRetentionDays, UpdateSourceTrigger=PropertyChanged}" MinHeight="32" />
                        </StackPanel>
                        <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                            <CheckBox IsChecked="{Binding SaveOriginalImage}" Content="保存原图" Margin="0,0,0,6" />
                            <CheckBox IsChecked="{Binding SaveResultImage}" Content="保存结果图" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource PanelBorderStyle}" Padding="14">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8A5;" Width="24" />
                                <TextBlock Text="通用预留参数" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,1,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding AddParameterCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="新增一条预留参数">
                                    <TextBlock Text="新增参数" />
                                </Button>
                                <Button Command="{Binding RemoveParameterCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="移除当前选中参数">
                                    <TextBlock Text="移除参数" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <DataGrid ItemsSource="{Binding Parameters}"
                                  SelectedItem="{Binding SelectedParameter}"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                                <DataGridTextColumn Header="键" Binding="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                <DataGridTextColumn Header="值" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                <DataGridTextColumn Header="单位" Binding="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                <DataGridTextColumn Header="说明" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </ScrollViewer>
            </TabItem>

            <TabItem Header="通讯通道">
                <TabControl Style="{StaticResource SettingsTabControlStyle}"
                            ItemContainerStyle="{StaticResource SettingsTabItemStyle}"
                            Margin="0,10,0,0">
                    <TabItem Header="通道配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <Grid MinHeight="852">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="420" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="420" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE774;" Width="24" />
                                    <TextBlock Text="TCP 通道" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                                    <TextBlock Text="配方 TCP 通讯工具按 Key 引用这里的通道"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="16,1,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding AddTcpChannelCommand}" Style="{StaticResource ActionButtonStyle}">
                                        <TextBlock Text="新增 TCP" />
                                    </Button>
                                    <Button Command="{Binding RemoveTcpChannelCommand}" Style="{StaticResource ActionButtonStyle}">
                                        <TextBlock Text="移除 TCP" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <DataGrid ItemsSource="{Binding TcpChannels}"
                                      SelectedItem="{Binding SelectedTcpChannel}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                                    <DataGridTemplateColumn Header="连接策略" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding ConnectionPolicyOptions}"
                                                          SelectedItem="{Binding ConnectionPolicyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridTemplateColumn Header="模式" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding ModeOptions}"
                                                          SelectedItem="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="目标/监听地址" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding HostOptions}"
                                                          SelectedItem="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Text="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ToolTip="{Binding HostUsageText}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="端口" Binding="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                    <DataGridTextColumn Header="连接超时" Binding="{Binding ConnectTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                    <DataGridTextColumn Header="接收超时" Binding="{Binding ReceiveTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                    <DataGridTemplateColumn Header="拆帧" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding FrameModeOptions}"
                                                          SelectedItem="{Binding FrameMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding FrameMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="分隔符" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DelimiterOptions}"
                                                          SelectedItem="{Binding Delimiter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding Delimiter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Text="{Binding Delimiter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="固定长度" Binding="{Binding FixedFrameLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridTemplateColumn Header="长度头" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding LengthPrefixByteOptions}"
                                                          SelectedItem="{Binding LengthPrefixBytes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding LengthPrefixBytes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="小端" Binding="{Binding LengthPrefixLittleEndian, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                                    <DataGridTextColumn Header="最大帧长" Binding="{Binding MaxFrameLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridCheckBoxColumn Header="补分隔符" Binding="{Binding AppendDelimiterOnSend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridCheckBoxColumn Header="加长度头" Binding="{Binding PrefixPayloadOnSend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridTextColumn Header="说明" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="280" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE950;" Width="24" />
                                    <TextBlock Text="串口通道" Style="{StaticResource SectionTitleStyle}" Margin="8,0,0,0" />
                                    <TextBlock Text="配方串口通讯工具按 Key 引用这里的通道"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="16,1,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding AddSerialChannelCommand}" Style="{StaticResource ActionButtonStyle}">
                                        <TextBlock Text="新增串口" />
                                    </Button>
                                    <Button Command="{Binding RemoveSerialChannelCommand}" Style="{StaticResource ActionButtonStyle}">
                                        <TextBlock Text="移除串口" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <DataGrid ItemsSource="{Binding SerialChannels}"
                                      SelectedItem="{Binding SelectedSerialChannel}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                                    <DataGridTemplateColumn Header="连接策略" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding ConnectionPolicyOptions}"
                                                          SelectedItem="{Binding ConnectionPolicyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridTemplateColumn Header="串口" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding PortNameOptions}"
                                                          SelectedItem="{Binding PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Text="{Binding PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="波特率" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding BaudRateOptions}"
                                                          SelectedItem="{Binding BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValue="{Binding BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Text="{Binding BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          MinHeight="30" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
