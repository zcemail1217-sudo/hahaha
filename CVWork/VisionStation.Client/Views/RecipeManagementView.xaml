<UserControl x:Class="VisionStation.Client.Views.RecipeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:VisionStation.Vision.UI.Behaviors;assembly=VisionStation.Vision.UI"
             xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls;assembly=VisionStation.Vision.UI"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="CompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="RecipePageMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RecipePageMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="RecipePageMenuIconStyle" TargetType="TextBlock" BasedOn="{StaticResource IconTextStyle}">
            <Setter Property="Width" Value="16" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style x:Key="InlineToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#FF17242D" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FF111820" />
                                <Setter Property="BorderBrush" Value="#FF26343D" />
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PageComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PageCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,18,10" />
        </Style>

        <Style x:Key="SummaryChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="ProcessSummaryChipStyle" TargetType="Border" BasedOn="{StaticResource SummaryChipStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,8,6" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="RecipeScrollRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbRoot"
                                Background="#FF31414B"
                                BorderBrush="#6637EBC8"
                                BorderThickness="1"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#FF3F5663" />
                                <Setter TargetName="ThumbRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="ThumbRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Background" Value="#FF0B1218" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border x:Name="TrackRoot"
                                Width="{TemplateBinding Width}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Track x:Name="PART_Track"
                                   Margin="2"
                                   IsDirectionReversed="True"
                                   IsEnabled="{TemplateBinding IsMouseOver}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource RecipeScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource RecipeScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource RecipeScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="10" />
                                <Setter Property="MinHeight" Value="10" />
                                <Setter TargetName="TrackRoot" Property="Width" Value="Auto" />
                                <Setter TargetName="TrackRoot" Property="Height" Value="{Binding Height, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeScrollViewerStyle" TargetType="ScrollViewer">
            <Style.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource RecipeScrollBarStyle}" />
            </Style.Resources>
        </Style>

        <Style x:Key="PageDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Style.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource RecipeScrollBarStyle}" />
            </Style.Resources>
        </Style>

        <Style x:Key="ProcessToolboxButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF1B3D40" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FF111820" />
                                <Setter Property="BorderBrush" Value="#FF26343D" />
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProcessStepListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Style.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource RecipeScrollBarStyle}" />
            </Style.Resources>
        </Style>

        <Style x:Key="ProcessStepListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0"
                                      IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="0,0,0,12" />
                            <Border Grid.Row="1"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeSingleContentStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="0"
                Margin="0,0,0,8">
            <Grid MinHeight="42">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0"
                      Style="{StaticResource RecipePageMenuStyle}"
                      Margin="8,0,0,0">
                    <MenuItem Command="{Binding NewRecipeCommand}" Style="{StaticResource RecipePageMenuItemStyle}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource RecipePageMenuIconStyle}" Text="&#xE710;" />
                                <TextBlock Text="新建(N)" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding DuplicateRecipeCommand}" Style="{StaticResource RecipePageMenuItemStyle}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource RecipePageMenuIconStyle}" Text="&#xE8C8;" />
                                <TextBlock Text="复制(C)" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding DeleteRecipeCommand}" Style="{StaticResource RecipePageMenuItemStyle}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource RecipePageMenuIconStyle}" Text="&#xE74D;" />
                                <TextBlock Text="删除(D)" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding SetCurrentRecipeCommand}" Style="{StaticResource RecipePageMenuItemStyle}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource RecipePageMenuIconStyle}" Text="&#xE73E;" />
                                <TextBlock Text="设为当前(P)" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding SaveCommand}" Style="{StaticResource RecipePageMenuItemStyle}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource RecipePageMenuIconStyle}" Text="&#xE74E;" />
                                <TextBlock Text="保存(S)" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding ReloadCommand}" Style="{StaticResource RecipePageMenuItemStyle}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource RecipePageMenuIconStyle}" Text="&#xE72C;" />
                                <TextBlock Text="刷新(F5)" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </Menu>

                <TextBlock Grid.Column="1"
                           Margin="18,0,18,0"
                           Text="{Binding RecipeDirectory, StringFormat=配方目录：{0}}"
                           ToolTip="{Binding RecipeDirectory}"
                           TextTrimming="CharacterEllipsis"
                           Style="{StaticResource HelperTextStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8A5;" Width="24" />
                    <TextBlock Text="配方配置中心"
                               FontSize="17"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                    <Border Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentLineBrush}"
                            BorderThickness="1"
                            Padding="7,2"
                            Margin="12,0,0,0">
                        <TextBlock Text="{Binding CurrentRecipeBadge}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11.5" />
                    </Border>
                    <Border Background="#22FFC95A"
                            BorderBrush="{StaticResource WarnBrush}"
                            BorderThickness="1"
                            Padding="7,2"
                            Margin="8,0,0,0">
                        <TextBlock Text="{Binding ChangeStateText}"
                                   Foreground="{StaticResource WarnBrush}"
                                   FontSize="11.5" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="产品型号配方列表" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Recipes.Count, StringFormat=共 {0} 个产品型号，选中后在右侧编辑运行流程。}"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Recipes}"
                              SelectedItem="{Binding SelectedRecipe}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              Style="{StaticResource PageDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="当前" Binding="{Binding IsCurrent}" Width="58" />
                            <DataGridTextColumn Header="配方名" Binding="{Binding Name}" Width="1.1*" />
                            <DataGridTextColumn Header="产品型号" Binding="{Binding ProductCode}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="14">
                <Grid>
                    <TabControl Style="{StaticResource RecipeSingleContentStyle}" SelectedIndex="1">
                        <TabItem Header="可填参数" Style="{StaticResource RecipeTabItemStyle}" Visibility="Collapsed" IsEnabled="False">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Style="{StaticResource RecipeScrollViewerStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource SectionCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,16">
                                                <TextBlock Text="产品基础信息" Style="{StaticResource SectionTitleStyle}" />
                                                <TextBlock Text="这里是操作员或调机人员最常改的产品身份信息，保存后会进入当前配方文件。"
                                                           Style="{StaticResource HelperTextStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Margin="0,0,12,14">
                                                <TextBlock Text="配方 ID" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding RecipeId, Mode=OneWay}"
                                                         IsReadOnly="True" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,14">
                                                <TextBlock Text="产品型号编码" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Margin="0,0,12,14">
                                                <TextBlock Text="配方名称" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding RecipeName, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="12,0,0,14">
                                                <TextBlock Text="当前视觉流程摘要" Style="{StaticResource EditorLabelStyle}" />
                                                <Border Background="{StaticResource AccentSoftBrush}"
                                                        BorderBrush="{StaticResource AccentLineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="5"
                                                        Padding="10,9">
                                                    <TextBlock Text="{Binding FlowSummaryText}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="14"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2">
                                                <TextBlock Text="说明" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         MinHeight="78"
                                                         TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SectionCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="0.65*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.ColumnSpan="4" Margin="0,0,0,16">
                                                <TextBlock Text="相机与追溯参数" Style="{StaticResource SectionTitleStyle}" />
                                                <TextBlock Text="采图参数、是否硬触发、OK/NG 图像保存策略都放在这里，方便换型时一次检查。"
                                                           Style="{StaticResource HelperTextStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Margin="0,0,12,14">
                                                <TextBlock Text="相机 ID" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding CameraId, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,12,14">
                                                <TextBlock Text="相机名称" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding CameraDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,12,14">
                                                <TextBlock Text="曝光(us)" Style="{StaticResource EditorLabelStyle}" />
                                                <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                         Text="{Binding ExposureTimeUs, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="3" Margin="12,26,0,14">
                                                <CheckBox Style="{StaticResource PageCheckBoxStyle}"
                                                          Content="硬触发"
                                                          IsChecked="{Binding HardwareTrigger}" />
                                            </StackPanel>

                                            <WrapPanel Grid.Row="2" Grid.ColumnSpan="4">
                                                <StackPanel Width="150" Margin="0,0,14,8">
                                                    <TextBlock Text="增益" Style="{StaticResource EditorLabelStyle}" />
                                                    <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                             Text="{Binding Gain, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <CheckBox Style="{StaticResource PageCheckBoxStyle}"
                                                          Content="保存 OK 图"
                                                          IsChecked="{Binding SaveOkImages}"
                                                          Margin="0,28,18,10" />
                                                <CheckBox Style="{StaticResource PageCheckBoxStyle}"
                                                          Content="保存 NG 图"
                                                          IsChecked="{Binding SaveNgImages}"
                                                          Margin="0,28,18,10" />
                                                <StackPanel Width="150" Margin="0,0,14,8">
                                                    <TextBlock Text="保留天数" Style="{StaticResource EditorLabelStyle}" />
                                                    <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                             Text="{Binding RetentionDays, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Width="170" Margin="0,0,0,8">
                                                    <TextBlock Text="容量上限(MB)" Style="{StaticResource EditorLabelStyle}" />
                                                    <TextBox Style="{StaticResource PageTextBoxStyle}"
                                                             Text="{Binding MaxStorageMegabytes, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SectionCardStyle}">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                                <StackPanel Width="340">
                                                    <TextBlock Text="产品参数" Style="{StaticResource SectionTitleStyle}" />
                                                    <TextBlock Text="这里放人工可填写或换型时要确认的工艺参数。"
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                                <Button Command="{Binding AddProductParameterCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="新增参数" />
                                                <Button Command="{Binding RemoveProductParameterCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="删除参数" />
                                            </StackPanel>
                                            <Border DockPanel.Dock="Top"
                                                    Background="{StaticResource SurfaceAltBrush}"
                                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12"
                                                    Margin="0,0,0,12">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                                        <StackPanel Width="360">
                                                            <TextBlock Text="变量调用"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="选中变量后，可把 ${Key} 写入当前选中的产品参数值。"
                                                                       Style="{StaticResource HelperTextStyle}"
                                                                       Margin="0,6,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding SelectedRecipeVariableReference, StringFormat=当前调用：{0}}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,8" />
                                                        <Button Command="{Binding UseVariableInProductParameterCommand}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="调用到参数" />
                                                    </StackPanel>

                                                    <DataGrid ItemsSource="{Binding RecipeVariables}"
                                                              SelectedItem="{Binding SelectedRecipeVariable}"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              IsReadOnly="True"
                                                              MinHeight="120"
                                                              MaxHeight="170"
                                                              Style="{StaticResource PageDataGridStyle}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="参数 Key" Binding="{Binding Key}" Width="160" />
                                                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="160" />
                                                            <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="100" />
                                                            <DataGridTextColumn Header="调用写法" Binding="{Binding ReferenceText}" Width="150" />
                                                            <DataGridTextColumn Header="默认值" Binding="{Binding DefaultValue}" Width="120" />
                                                            <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="80" />
                                                            <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="*" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </DockPanel>
                                            </Border>

                                            <DataGrid ItemsSource="{Binding ProductParameters}"
                                                      SelectedItem="{Binding SelectedProductParameter}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      MinHeight="180"
                                                      MaxHeight="300"
                                                      Style="{StaticResource PageDataGridStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="参数名" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                                    <DataGridTextColumn Header="数值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                                                    <DataGridTextColumn Header="单位" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                                    <DataGridCheckBoxColumn Header="可编辑" Binding="{Binding Editable}" Width="90" />
                                                    <DataGridTextColumn Header="说明" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>

                                    <Border Style="{StaticResource SectionCardStyle}">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                                <StackPanel Width="420">
                                                    <TextBlock Text="视觉结果与外部映射" Style="{StaticResource SectionTitleStyle}" />
                                                    <TextBlock Text="把视觉流程产出的字段映射成可被 PLC、MES、变量中心或后续流程引用的结果。"
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                                <Button Command="{Binding AddVisionResultCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="新增结果项" />
                                                <Button Command="{Binding RemoveVisionResultCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="删除结果项" />
                                            </StackPanel>
                                            <DataGrid ItemsSource="{Binding VisionResults}"
                                                      SelectedItem="{Binding SelectedVisionResult}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      MinHeight="200"
                                                      MaxHeight="340"
                                                      Style="{StaticResource PageDataGridStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="结果名" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                                    <DataGridTextColumn Header="流程" Binding="{Binding FlowId, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                                                    <DataGridComboBoxColumn Header="来源输出"
                                                                            SelectedValueBinding="{Binding SourceAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            SelectedValuePath="Address"
                                                                            DisplayMemberPath="DisplayText"
                                                                            Width="240">
                                                        <DataGridComboBoxColumn.ElementStyle>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Setter Property="ItemsSource" Value="{Binding DataContext.VisionResultSourceOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                            </Style>
                                                        </DataGridComboBoxColumn.ElementStyle>
                                                        <DataGridComboBoxColumn.EditingElementStyle>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Setter Property="ItemsSource" Value="{Binding DataContext.VisionResultSourceOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                            </Style>
                                                        </DataGridComboBoxColumn.EditingElementStyle>
                                                    </DataGridComboBoxColumn>
                                                    <DataGridComboBoxColumn Header="类型"
                                                                            SelectedItemBinding="{Binding DataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            Width="110">
                                                        <DataGridComboBoxColumn.ElementStyle>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Setter Property="ItemsSource" Value="{Binding DataContext.VisionResultDataTypeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                            </Style>
                                                        </DataGridComboBoxColumn.ElementStyle>
                                                        <DataGridComboBoxColumn.EditingElementStyle>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Setter Property="ItemsSource" Value="{Binding DataContext.VisionResultDataTypeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                            </Style>
                                                        </DataGridComboBoxColumn.EditingElementStyle>
                                                    </DataGridComboBoxColumn>
                                                    <DataGridTextColumn Header="单位" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                                    <DataGridCheckBoxColumn Header="参与判定" Binding="{Binding ParticipateInJudge}" Width="90" />
                                                    <DataGridTextColumn Header="外部别名" Binding="{Binding ExternalAlias, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                                                    <DataGridTextColumn Header="PLC 地址" Binding="{Binding PlcAddress, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                                                    <DataGridTextColumn Header="说明" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>

                                    <Border Style="{StaticResource SectionCardStyle}">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                                <StackPanel Width="420">
                                                    <TextBlock Text="PLC 信号与轴动作预留" Style="{StaticResource SectionTitleStyle}" />
                                                    <TextBlock Text="PLC 等待/回写放上面，复杂轴卡动作序列先保留在下面，运行流程可以引用这些配置。"
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                                <Button Command="{Binding AddPlcSignalCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="新增信号" />
                                                <Button Command="{Binding RemovePlcSignalCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="删除信号" />
                                                <Button Command="{Binding AddMotionSequenceCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="新增轴序列" />
                                                <Button Command="{Binding RemoveMotionSequenceCommand}"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Content="删除轴序列" />
                                            </StackPanel>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="14" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <DataGrid Grid.Row="0"
                                                          ItemsSource="{Binding PlcSignals}"
                                                          SelectedItem="{Binding SelectedPlcSignal}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          MinHeight="180"
                                                          MaxHeight="280"
                                                          Style="{StaticResource PageDataGridStyle}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="信号名" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="170" />
                                                        <DataGridTextColumn Header="地址" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                                        <DataGridTextColumn Header="方向" Binding="{Binding Direction, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                                        <DataGridTextColumn Header="触发值" Binding="{Binding TriggerValue, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                                        <DataGridTextColumn Header="超时(ms)" Binding="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                                        <DataGridCheckBoxColumn Header="阻塞等待" Binding="{Binding Blocking}" Width="100" />
                                                        <DataGridTextColumn Header="说明" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>

                                                <DataGrid Grid.Row="2"
                                                          ItemsSource="{Binding MotionSequences}"
                                                          SelectedItem="{Binding SelectedMotionSequence}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          MinHeight="160"
                                                          MaxHeight="260"
                                                          Style="{StaticResource PageDataGridStyle}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="序列名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="220" />
                                                        <DataGridTextColumn Header="控制器配置" Binding="{Binding ControllerProfile, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="80" />
                                                        <DataGridTextColumn Header="步骤数" Binding="{Binding StepCount}" Width="90" IsReadOnly="True" />
                                                        <DataGridTextColumn Header="说明" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="运行流程" Style="{StaticResource RecipeTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="285" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource SectionCardStyle}"
                                        Padding="12"
                                        Margin="0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="工具箱"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Style="{StaticResource RecipeScrollViewerStyle}">
                                            <ItemsControl ItemsSource="{Binding RuntimeProcessToolboxItems}">
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="{x:Type ContentPresenter}">
                                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.AddProcessToolCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                behaviors:CommandDragDropBehavior.EnableDrag="True"
                                                                behaviors:CommandDragDropBehavior.DragData="{Binding}"
                                                                Style="{StaticResource ProcessToolboxButtonStyle}">
                                                            <Border Background="{StaticResource SurfaceAltBrush}"
                                                                    BorderBrush="{Binding AccentBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10,8"
                                                                    HorizontalAlignment="Stretch">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="4" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Background="{Binding AccentBrush}"
                                                                            CornerRadius="2" />
                                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   FontSize="13.5"
                                                                                   FontWeight="SemiBold" />
                                                                        <TextBlock Text="{Binding Subtitle}"
                                                                                   Style="{StaticResource HelperTextStyle}"
                                                                                   Margin="0,4,0,0"
                                                                                   MaxHeight="36" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <Border x:Name="ProcessStepPanel"
                                        Grid.Column="2"
                                        Style="{StaticResource SectionCardStyle}"
                                        Padding="12"
                                        Margin="0"
                                        behaviors:CommandDragDropBehavior.DropCommand="{Binding AddProcessToolCommand}">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="步骤列表"
                                                       Style="{StaticResource SectionTitleStyle}"
                                                       Margin="0" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="从上到下执行"
                                                           Style="{StaticResource HelperTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />
                                                <Button Content="{Binding TestRunButtonText}"
                                                        Command="{Binding TestRunRecipeCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                            <Setter Property="Margin" Value="0" />
                                                            <Setter Property="Padding" Value="14,5" />
                                                            <Setter Property="MinWidth" Value="104" />
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="暂停"
                                                        Command="{Binding PauseTestRunCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                            <Setter Property="Margin" Value="8,0,0,0" />
                                                            <Setter Property="Padding" Value="12,5" />
                                                            <Setter Property="MinWidth" Value="72" />
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="复位"
                                                        Command="{Binding ResetTestRunCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                            <Setter Property="Margin" Value="8,0,0,0" />
                                                            <Setter Property="Padding" Value="12,5" />
                                                            <Setter Property="MinWidth" Value="72" />
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <ListBox x:Name="ProcessStepsListBox"
                                                 ItemsSource="{Binding ProcessSteps}"
                                                 SelectedItem="{Binding SelectedProcessStep}"
                                                 Style="{StaticResource ProcessStepListBoxStyle}"
                                                 ItemContainerStyle="{StaticResource ProcessStepListItemStyle}"
                                                 MouseDoubleClick="ProcessStepsListBox_MouseDoubleClick">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                                            BorderBrush="{Binding AccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10,8"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <Border.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                <MenuItem Header="上移"
                                                                          Command="{Binding PlacementTarget.Tag.MoveProcessStepLeftCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                          CommandParameter="{Binding}" />
                                                                <MenuItem Header="下移"
                                                                          Command="{Binding PlacementTarget.Tag.MoveProcessStepRightCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                          CommandParameter="{Binding}" />
                                                                <MenuItem Header="删除步骤"
                                                                          Command="{Binding PlacementTarget.Tag.RemoveProcessStepItemCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                          CommandParameter="{Binding}" />
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="38" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="28"
                                                                    Height="28"
                                                                    Background="{Binding AccentBrush}"
                                                                    CornerRadius="14"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding StepNo}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold"
                                                                           Foreground="#FF071017" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" Margin="10,0,16,0">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding StepTypeText}"
                                                                               Foreground="{Binding AccentBrush}"
                                                                               FontWeight="SemiBold"
                                                                               Margin="0,0,12,0" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Name}"
                                                                               FontSize="14"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </Grid>
                                                                <TextBlock Text="{Binding StepTypeHint}"
                                                                           Style="{StaticResource HelperTextStyle}"
                                                                           Margin="0,4,0,0" />
                                                                <WrapPanel Margin="0,7,0,0">
                                                                    <Border Style="{StaticResource ProcessSummaryChipStyle}">
                                                                        <TextBlock Text="{Binding DeviceKey, StringFormat=设备 {0}}"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                    </Border>
                                                                    <Border Style="{StaticResource ProcessSummaryChipStyle}">
                                                                        <TextBlock Text="{Binding SignalId, StringFormat=信号 {0}}"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                    </Border>
                                                                    <Border Style="{StaticResource ProcessSummaryChipStyle}">
                                                                        <TextBlock Text="{Binding TimeoutMs, StringFormat=超时 {0}ms}"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                    </Border>
                                                                </WrapPanel>
                                                                <TextBlock Text="{Binding Description}"
                                                                           Style="{StaticResource HelperTextStyle}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <WrapPanel Margin="0,7,0,0">
                                                                    <Border Style="{StaticResource ProcessSummaryChipStyle}">
                                                                        <TextBlock Text="{Binding RuntimeStatusText, StringFormat=状态 {0}}"
                                                                                   Foreground="{Binding RuntimeStatusBrush}" />
                                                                    </Border>
                                                                    <Border Style="{StaticResource ProcessSummaryChipStyle}">
                                                                        <TextBlock Text="{Binding RuntimeDurationText}"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                    </Border>
                                                                    <Border Style="{StaticResource ProcessSummaryChipStyle}">
                                                                        <TextBlock Text="{Binding RuntimeResultText}"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                                   MaxWidth="420"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </Border>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <CheckBox Grid.Column="2"
                                                                      IsChecked="{Binding Enabled}"
                                                                      Style="{StaticResource PageCheckBoxStyle}"
                                                                      Margin="0" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="试运行日志"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,10" />
                    <ListBox x:Name="TestRunLogsListBox"
                             ItemsSource="{Binding TestRunLogs}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="TestRunLogsListBox_PreviewMouseWheel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Time}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LevelText}"
                                               FontSize="12"
                                               Foreground="{Binding LevelBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
        </Border>

        <controls:SimpleLoadingOverlay Grid.RowSpan="3"
                                       Panel.ZIndex="20"
                                       IsActive="{Binding IsBusy}"
                                       Message="{Binding StatusText}" />
    </Grid>
</UserControl>

