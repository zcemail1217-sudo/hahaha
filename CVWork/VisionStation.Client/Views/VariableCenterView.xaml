<UserControl x:Class="VisionStation.Client.Views.VariableCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionStation.Vision.UI.Controls;assembly=VisionStation.Vision.UI"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="VariableDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>

        <Style x:Key="SummaryChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,10,8" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkbenchBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="16"
                Margin="0,0,0,12"
                MinHeight="106">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8AB;" Width="30" />
                        <TextBlock Text="变量参数库"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentLineBrush}"
                                BorderThickness="1"
                                Padding="8,2"
                                Margin="14,0,0,0">
                            <TextBlock Text="{Binding CurrentRecipeBadge}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="11.5" />
                        </Border>
                        <Border Background="#22FFC95A"
                                BorderBrush="{StaticResource WarnBrush}"
                                BorderThickness="1"
                                Padding="8,2"
                                Margin="8,0,0,0">
                            <TextBlock Text="{Binding ChangeStateText}"
                                       Foreground="{StaticResource WarnBrush}"
                                       FontSize="11.5" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="在这里新建参数并选择类型；配方页可以用 ${参数Key} 调用它，例如 ${ProductWidth}。"
                               Style="{StaticResource HelperTextStyle}"
                               Margin="34,8,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="16,0,0,0">
                    <Button Command="{Binding AddVariableCommand}"
                            CommandParameter="Parameter"
                            Style="{StaticResource CompactActionButtonStyle}"
                            Content="新建参数" />
                    <Button Command="{Binding SyncFromRecipeCommand}"
                            Style="{StaticResource CompactActionButtonStyle}"
                            Content="从配方生成" />
                    <Button Command="{Binding RemoveVariableCommand}"
                            Style="{StaticResource CompactActionButtonStyle}"
                            Content="删除参数" />
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource CompactActionButtonStyle}"
                            Content="保存参数" />
                    <Button Command="{Binding ReloadCommand}"
                            Style="{StaticResource CompactActionButtonStyle}"
                            Content="刷新"
                            Margin="0,0,0,8" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="0,0,0,1"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="参数所属配方"
                                       FontSize="17"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="参数随配方保存，切换产品型号时会加载对应的参数库。"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding Recipes}"
                              SelectedItem="{Binding SelectedRecipe}"
                              IsReadOnly="True"
                              BorderThickness="0"
                              Style="{StaticResource VariableDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="当前" Binding="{Binding IsCurrent}" Width="58" />
                            <DataGridTextColumn Header="配方" Binding="{Binding Name}" Width="1.1*" />
                            <DataGridTextColumn Header="型号" Binding="{Binding ProductCode}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="14"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding RecipeName}"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ProductCode, StringFormat=产品型号：{0}}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="15"
                                       Margin="0,6,0,0" />
                            <TextBlock Text="参数 Key 是配方调用名；类型决定它是文本、数值、整数、布尔值还是结构化数据。"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Style="{StaticResource SummaryChipStyle}">
                                <TextBlock Text="{Binding VariableCount, StringFormat=参数 {0}}" />
                            </Border>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="14"
                        Margin="0,0,0,12">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8AB;" Width="24" />
                            <TextBlock Text="参数监视表"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0" />
                            <TextBlock Text="在这里维护变量定义，同时查看每个变量的当前值、来源和刷新时间。"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="16,2,0,0" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Variables}"
                                  SelectedItem="{Binding SelectedVariable}"
                                  Style="{StaticResource VariableDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="状态" Width="86" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#141D2A33"
                                                    BorderBrush="{Binding ValueStateBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ValueStateText}"
                                                           Foreground="{Binding ValueStateBrush}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="参数 Key" Binding="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                <DataGridTemplateColumn Header="参数类型" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.DataTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding DataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      MinHeight="28" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="当前值" Binding="{Binding DisplayedCurrentValue}" Width="160" IsReadOnly="True" />
                                <DataGridTextColumn Header="时间" Binding="{Binding LiveValueUpdatedAtText}" Width="90" IsReadOnly="True" />
                                <DataGridTextColumn Header="调用写法" Binding="{Binding ReferenceText}" Width="140" IsReadOnly="True" />
                                <DataGridTextColumn Header="说明" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="260" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelBorderStyle}"
                            Padding="14">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE8A5;" Width="24" />
                                <TextBlock Text="当前配方已有调用点"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="这些位置都可以写入 ${参数Key}。"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="16,2,0,0" />
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding References}"
                                      IsReadOnly="True"
                                      Style="{StaticResource VariableDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="类别" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="#141D2A33"
                                                        BorderBrush="{Binding Brush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="8,3">
                                                    <TextBlock Text="{Binding Kind}"
                                                               Foreground="{Binding Brush}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="180" />
                                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="220" />
                                    <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelBorderStyle}"
                            Padding="14">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE9D9;" Width="24" />
                                <TextBlock Text="最新运行值"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="{Binding RuntimeValueCount, StringFormat=上一轮检测共 {0} 项}"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="16,2,0,0" />
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding RuntimeValues}"
                                      IsReadOnly="True"
                                      Style="{StaticResource VariableDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="类别" Binding="{Binding Kind}" Width="120" />
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="220" />
                                    <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*" />
                                    <DataGridTextColumn Header="时间" Binding="{Binding UpdatedAt}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelHeaderBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
        </Border>

        <controls:SimpleLoadingOverlay Grid.RowSpan="3"
                                       Panel.ZIndex="20"
                                       IsActive="{Binding IsBusy}" />
    </Grid>
</UserControl>
